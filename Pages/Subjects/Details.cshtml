@page "{id:int}"
@model Vyuka.Pages.Subjects.DetailsModel

<h1>@Model.Subject.Name</h1>

<div class="card" style="max-width:600px;">
    <div class="card-body">

        @* Obrázek předmětu *@
        @if (!string.IsNullOrEmpty(Model.Subject.ImageUrl))
        {
            <div class="mb-3 text-center">
                <img src="/images/@Model.Subject.ImageUrl"
                     style="max-width:100%;max-height:250px;border-radius:6px;" />
            </div>
        }

        <h5>Témata</h5>

        @* Seznam témat *@
        @if (Model.Topics == null || Model.Topics.Count == 0)
        {
            <p><em>Žádná témata nejsou zadána.</em></p>
        }
        else
        {
            <ul class="list-group mb-3">
                @foreach (var t in Model.Topics)
                {
                    <li class="list-group-item">@t.Name</li>
                }
            </ul>
        }

        <hr />

        <h5>Přidat nové téma</h5>

        <form method="post" asp-page-handler="AddTopic">
            <div class="input-group mb-3">
                <input asp-for="NewTopic" class="form-control" placeholder="Napište nové téma..." />
                <button type="submit" class="btn btn-success">+ Přidat</button>
            </div>
        </form>

        <hr />

        @* 🔵 NOVÁ SEKCE – IMPORT TÉMAT *@
        <h5>Importovat témata</h5>
        <p class="text-muted">Vložte jedno téma na každý řádek.</p>

        <form method="post" asp-page-handler="Import">
            <textarea asp-for="ImportText" class="form-control" rows="6"
                      placeholder="Např.:
            Rovnice
            Zlomky
            Geometrie
            Funkce"></textarea>

            <button type="submit" class="btn btn-warning mt-2">Importovat témata</button>
        </form>

        <hr />

        <a asp-page="Edit" asp-route-id="@Model.Subject.Id" class="btn btn-primary">Upravit</a>
        <a asp-page="Index" class="btn btn-secondary">Zpět</a>

    </div>
</div>