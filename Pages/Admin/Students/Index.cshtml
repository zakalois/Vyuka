@page "/Admin/Students"
@model Vyuka.Pages.Admin.Students.IndexModel

<style>
    .row-pink {
        background-color: #f8d7da !important;
    }
</style>

<h1>Seznam studentů</h1>

<!-- Tlačítko přes celou šířku řádku -->
<div class="d-grid mb-3">
    <a class="btn btn-primary btn-lg w-100" asp-page="Create">
        Přidat studenta
    </a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Příjmení</th>
            <th>Jméno</th>
            <th>Věk</th>
            <th>Email</th>
            <th>Telefon</th>
            <th>Škola</th>
            <th>Adresa</th>
            <th>Jméno rodiče</th>
            <th>Příjmení rodiče</th>
            <th>Telefon rodiče</th>
            <th>Email rodiče</th>

            <!-- ⭐ NOVÝ SLOUPEC -->
            <th>Odučeno</th>

            <th class="text-center" style="width:110px;">Akce</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Students)
        {
            <tr class="@(item.IsActive ? "" : "row-pink")">

                <td>@item.LastName</td>
                <td>@item.FirstName</td>
                <td>@item.Age</td>
                <td>@item.Email</td>
                <td>@item.Phone</td>
                <td>@item.School</td>
                <td>@item.Address</td>
                <td>@item.ParentFirstName</td>
                <td>@item.ParentLastName</td>
                <td>@item.ParentPhone</td>
                <td>@item.ParentEmail</td>

                <!-- ⭐ ZDE SE ZOBRAZÍ ODUČENÉ HODINY -->
                <td>@Model.TaughtHours[item.Id] h</td>

                <td class="text-center" style="white-space:nowrap;">

                    <a asp-page="Edit" asp-route-id="@item.Id" class="text-primary me-2" title="Upravit">
                        <i class="bi bi-pencil-square"></i>
                    </a>

                    <a asp-page="Details" asp-route-id="@item.Id" class="text-info me-2" title="Detail">
                        <i class="bi bi-search"></i>
                    </a>

                    <a asp-page="Delete" asp-route-id="@item.Id" class="text-danger me-3" title="Smazat">
                        <i class="bi bi-trash"></i>
                    </a>

                    <form method="post" asp-page="Toggle" asp-route-id="@item.Id" style="display:inline;">
                        @if (item.IsActive)
                        {
                            <button class="btn btn-danger btn-sm" title="Deaktivovat">
                                <i class="bi bi-person-dash"></i>
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-success btn-sm" title="Aktivovat">
                                <i class="bi bi-person-check"></i>
                            </button>
                        }
                    </form>

                </td>

            </tr>
        }
    </tbody>
</table>
