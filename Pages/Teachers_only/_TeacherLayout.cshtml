@using Microsoft.AspNetCore.Identity
@inject UserManager<Vyuka.Models.AppUser> UserManager
@{
    var teacher = await UserManager.GetUserAsync(User);
}

@inherits Microsoft.AspNetCore.Mvc.Razor.RazorPage<dynamic>
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@teacher.LastName @teacher.FirstName – Výuka</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <!-- HORNÍ NAVIGACE -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container-fluid">

            <!-- Jméno učitele jako odkaz na dashboard -->
            <a class="navbar-brand" asp-page="/Teachers_only/Dashboard">
                @teacher.LastName @teacher.FirstName
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#teacherNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="teacherNav">

                <!-- Levé menu -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Teachers_only/Students/Index">
                            <i class="bi bi-people"></i> Přehled studentů
                        </a>
                    </li>


                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Teachers_only/Lessons">Přehled hodin</a>
                    </li>

                    <!-- NOVÉ POLOŽKY -->
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Teachers_only/Lessons/Create">Přidat hodinu</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Teachers_only/Today">Dnešní hodiny</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Teachers_only/Schedule">Týdenní rozvrh</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Teachers_only/Notifications">Upozornění</a>
                    </li>

                </ul>

                <!-- Pravá část -->
                <div class="d-flex">

                    <button id="themeToggle" class="btn btn-outline-light me-2">Tmavý/Světlý</button>

                    <form method="post" asp-page="/Account/Logout">
                        <button class="btn btn-danger">Odhlásit</button>
                    </form>

                </div>

            </div>

        </div>
    </nav>



    <!-- OBSAH STRÁNKY -->
    <div class="container">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Přepínání režimu -->
    <script>
            (function () {
                const body = document.body;
                const toggle = document.getElementById('themeToggle');

                const saved = localStorage.getItem('theme');

                if (saved === 'light') {
                    body.classList.add('light');
                } else {
                    body.classList.add('dark');
                }

                toggle.addEventListener('click', function () {
                    if (body.classList.contains('dark')) {
                        body.classList.remove('dark');
                        body.classList.add('light');
                        localStorage.setItem('theme', 'light');
                    } else {
                        body.classList.remove('light');
                        body.classList.add('dark');
                        localStorage.setItem('theme', 'dark');
                    }
                });
            })();
    </script>

</body>
</html>
