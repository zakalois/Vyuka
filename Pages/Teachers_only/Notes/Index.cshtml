@page "{studentId?}"
@model Vyuka.Pages.Teachers_only.Notes.IndexModel

@{
    Layout = "/Pages/Teachers_only/_TeacherLayout.cshtml";
}


<h2>Poznámky</h2>

<style>
    .notes-table tr:nth-child(even) {
        background-color: #fff3cd !important; /* světle žlutá */
        color: #000 !important;
    }

    .notes-table tr:nth-child(odd) {
        background-color: #d4edda !important; /* světle zelená */
        color: #000 !important;
    }

    /* ⭐ DŮLEŽITÉ: text v celé tabulce musí být černý */
    .notes-table td,
    .notes-table th {
        color: #000 !important;
    }

    .note-author-me {
        font-weight: bold;
        color: #0f5132 !important;
    }

    .note-author-other {
        color: #495057 !important;
    }
</style>




<!-- FORMULÁŘ PRO VÝBĚR STUDENTA -->
<form method="post" asp-page-handler="Select">
    <div class="row mb-3">
        <div class="col-md-6">
            <label>Student</label>
            <select asp-for="SelectedStudentId" class="form-select" onchange="this.form.submit()">
                <option value="">-- Vyber studenta --</option>
                @foreach (var s in Model.Students)
                {
                    <option value="@s.Id">@s.LastName @s.FirstName</option>
                }
            </select>
        </div>
    </div>
</form>

@if (Model.SelectedStudent != null)
{
    <!-- INFO O STUDENTOVI -->
    <div class="alert alert-secondary">
        <strong>@Model.SelectedStudent.FirstName @Model.SelectedStudent.LastName</strong> |
        Tel: @Model.SelectedStudent.Phone |
        Email: @Model.SelectedStudent.Email |
        Zbývající hodiny: @Model.SelectedStudent.RemainingHours
    </div>

    <!-- FORMULÁŘ PRO PŘIDÁNÍ POZNÁMKY -->
    <form method="post" asp-page-handler="AddNote">
        <input type="hidden" asp-for="SelectedStudentId" />

        <div class="input-group mb-3">
            <input asp-for="NewNoteText" class="form-control" placeholder="Napište poznámku..." />
            <button class="btn btn-primary">Uložit</button>
        </div>
    </form>

    <!-- TABULKA POZNÁMEK – STEJNÁ JAKO ADMIN -->
    <table class="table notes-table">
        <thead>
            <tr>
                <th>Datum</th>
                <th>Autor</th>
                <th class="text-start">Poznámka</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var n in Model.Notes)
            {
                <tr>
                    <td>@n.Created.ToString("dd.MM.yyyy HH:mm")</td>

                    <td class="@(n.CreatedBy == Model.CurrentTeacherName ? "note-author-me" : "note-author-other")">
                        @n.CreatedBy
                    </td>

                    <td class="text-start">@n.Text</td>
                </tr>
            }
        </tbody>
    </table>

}
