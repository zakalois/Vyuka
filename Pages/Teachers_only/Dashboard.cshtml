@page "/Teachers_only/Dashboard"
@model Vyuka.Pages.Teachers_only.DashboardModel

@{
    Layout = "_TeacherLayout";
}

<div class="container mt-4">

    <!-- Horní tři boxy -->
    <div class="row">

        <!-- Dnešní hodiny -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <strong>Dnešní hodiny</strong>
                </div>
                <div class="card-body">
                    @if (Model.TodayLessons.Any())
                    {
                        <ul class="list-group">
                            @foreach (var lesson in Model.TodayLessons)
                            {
                                <li class="list-group-item">
                                    <strong>@lesson.Time</strong> – @lesson.Student (@lesson.Subject)
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p>Nemáte dnes žádné hodiny.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Moji studenti -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <strong>Moji studenti</strong>
                </div>
                <div class="card-body">
                    <p><strong>Celkem:</strong> @Model.StudentCount</p>
                    <p><strong>Nízký kredit:</strong> @Model.LowCreditCount</p>
                </div>
            </div>
        </div>

        <!-- Upozornění -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-danger text-white">
                    <strong>Upozornění</strong>
                </div>
                <div class="card-body">
                    @if (Model.Notifications.Any())
                    {
                        <ul class="list-group">
                            @foreach (var note in Model.Notifications)
                            {
                                <li class="list-group-item">@note</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p>Žádná upozornění.</p>
                    }
                </div>
            </div>
        </div>

    </div>

    <!-- Týdenní rozvrh přes celou šířku -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning">
            <strong>Týdenní rozvrh</strong>
        </div>

        <div class="card-body">

            <div class="row text-center">

                @foreach (var day in Model.WeeklySchedule)
                {
                    var isWeekend = day.Day == "Sobota" || day.Day == "Neděle";
                    var bg = isWeekend ? "bg-light border-danger" : "bg-light";

                    <div class="col border p-3 @bg">
                        <strong>@day.Day</strong><br />
                        @day.LessonCount hodin
                    </div>
                }

            </div>

        </div>
    </div>

</div>
