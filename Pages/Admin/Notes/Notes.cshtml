@page
@model Vyuka.Pages.Admin.Notes.NotesModel

<h2>Poznámky</h2>

<!-- FORMULÁŘ PRO VÝBĚR STUDENTA A UČITELE -->
<form method="post" asp-page-handler="Select">
    <div class="row mb-3">

        <div class="col-md-6">
            <label>Student</label>
            <select asp-for="SelectedStudentId" class="form-select" onchange="this.form.submit()">
                <option value="">-- Vyber studenta --</option>
                @foreach (var s in Model.Students)
                {
                    <option value="@s.Id">@s.LastName @s.FirstName</option>
                }
            </select>
        </div>

        <div class="col-md-6">
            <label>Učitel</label>
            <select asp-for="SelectedTeacherId" class="form-select" onchange="this.form.submit()">
                <option value="">-- Vyber učitele --</option>
                @foreach (var t in Model.Teachers)
                {
                    <option value="@t.Id">@t.User.LastName @t.User.FirstName</option>
                }
            </select>
        </div>

    </div>
</form>

@if (Model.SelectedStudent != null)
{
    <div class="alert alert-secondary">
        <strong>@Model.SelectedStudent.FirstName @Model.SelectedStudent.LastName</strong> |
        Tel: @Model.SelectedStudent.Phone |
        Email: @Model.SelectedStudent.Email |
        Zbývající hodiny: @Model.SelectedStudent.RemainingHours
    </div>
}

@if (Model.SelectedTeacher != null)
{
    <div class="alert alert-secondary">
        <strong>@Model.SelectedTeacher.User.FirstName @Model.SelectedTeacher.User.LastName</strong> |
        Tel: @Model.SelectedTeacher.User.PhoneNumber |
        Email: @Model.SelectedTeacher.User.Email
    </div>
}

@if (Model.SelectedStudentId != null || Model.SelectedTeacherId != null)
{
    <!-- FORMULÁŘ PRO PŘIDÁNÍ POZNÁMKY -->
    <form method="post" asp-page-handler="AddNote">

        <!-- ⭐ DŮLEŽITÉ: BEZ TOHO SE NIC NEULOŽÍ -->
        <input type="hidden" asp-for="SelectedStudentId" />
        <input type="hidden" asp-for="SelectedTeacherId" />

        <div class="input-group mb-3">
            <input asp-for="NewNoteText" class="form-control" placeholder="Napište poznámku..." />
            <button class="btn btn-primary">Uložit</button>
        </div>
    </form>

    <!-- TABULKA POZNÁMEK -->
    <table class="table notes-table">
        <thead>
            <tr>
                <th>Datum</th>
                <th>Autor</th>
                <th>Poznámka</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var n in Model.Notes)
            {
                <tr>
                    <td>@n.Created.ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="@(n.CreatedBy == "Alois Žák" ? "note-author-me" : "note-author-other")">
                        @n.CreatedBy
                    </td>
                    <td>@n.Text</td>
                </tr>
            }
        </tbody>
    </table>
}
