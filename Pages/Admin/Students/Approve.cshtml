@page "{id:int}"
@model ApproveModel

<h2>Schválit studenta</h2>

<p>Opravdu schválit studenta <strong>@Model.Student.FirstName @Model.Student.LastName</strong>?</p>

<form method="post">
    <button type="submit" class="btn btn-success">Schválit</button>
    <a asp-page="Pending" class="btn btn-secondary">Zpět</a>
</form>
