@page
@model Vyuka.Pages.Account.EditProfileModel
@{
    ViewData["Title"] = "Upravit profil";
}

<div class="edit-wrapper">

    <div class="edit-card">

        <h2 class="mb-4">Upravit profil</h2>

        <form method="post" enctype="multipart/form-data">

            <!-- FOTO -->
            <div class="photo-section mb-4 text-center">
                <img src="@(Model.CurrentPhotoPath ?? "/images/profile-placeholder.png")"
                     class="profile-photo-preview" alt="Profilová fotka" />

                <div class="mt-2">
                    <label class="form-label fw-bold">Změnit profilovou fotku</label>
                    <input type="file" class="form-control" asp-for="Input.PhotoFile" accept="image/*" />
                </div>
            </div>

            <!-- JMÉNO -->
            <div class="form-group mb-3">
                <label class="form-label">Jméno</label>
                <input type="text" class="form-control" asp-for="Input.FirstName" required />
            </div>

            <!-- PŘÍJMENÍ -->
            <div class="form-group mb-3">
                <label class="form-label">Příjmení</label>
                <input type="text" class="form-control" asp-for="Input.LastName" required />
            </div>

            <!-- EMAIL -->
            <div class="form-group mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" asp-for="Input.Email" required />
            </div>

            <!-- TELEFON -->
            <div class="form-group mb-3">
                <label class="form-label">Telefon (povinný)</label>
                <input type="tel" class="form-control" asp-for="Input.PhoneNumber" required />
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Uložit změny</button>
                <a href="/Account/Profile" class="btn btn-secondary">Zpět na profil</a>
            </div>

        </form>

    </div>

</div>

<style>
    .edit-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 40px;
    }

    .edit-card {
        background: #fff;
        padding: 30px;
        border-radius: 12px;
        width: 520px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }

    .profile-photo-preview {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #ddd;
    }

    .form-label {
        font-weight: 600;
    }

    .form-control {
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ccc;
    }

    .btn {
        padding: 10px 18px;
        border-radius: 6px;
        font-weight: 600;
        color: white;
        text-decoration: none;
    }

    .btn-primary { background: #007bff; }
    .btn-secondary { background: #6c757d; }
</style>
