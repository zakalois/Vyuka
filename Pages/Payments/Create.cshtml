@page
@model Vyuka.Pages.Payments.CreateModel

<h1>Přidat platbu</h1>

<form method="post">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label class="form-label">Student</label>
        <select asp-for="SelectedStudentId" asp-items="Model.StudentList" class="form-select">
            <option value="">-- Vyber studenta --</option>
        </select>
        <span asp-validation-for="SelectedStudentId" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Datum</label>
            <input asp-for="Date" type="date" class="form-control" />
            <span asp-validation-for="Date" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">Částka (Kč)</label>
            <input asp-for="Amount" class="form-control" />
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">Předplacené hodiny</label>
            <input asp-for="HoursPurchased" type="number" step="0.1" min="0" class="form-control" />
            <span asp-validation-for="HoursPurchased" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Cena za hodinu (Kč)</label>
            <input asp-for="PricePerHour" class="form-control" />
            <span asp-validation-for="PricePerHour" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">Způsob úhrady</label>
            <input asp-for="Method" class="form-control" placeholder="hotově / převodem" />
            <span asp-validation-for="Method" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">Poznámka</label>
            <input asp-for="Note" class="form-control" />
            <span asp-validation-for="Note" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-success">Uložit platbu</button>
</form>