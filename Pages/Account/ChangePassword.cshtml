@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Změna hesla";
}

<div class="container mt-4" style="max-width: 500px;">
    <h2>Změna hesla</h2>

    <form method="post">
        <div class="mb-3">
            <label class="form-label">Současné heslo</label>
            <input type="password" asp-for="CurrentPassword" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Nové heslo</label>
            <input type="password" asp-for="NewPassword" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary w-100">Změnit heslo</button>
    </form>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-info mt-3">@Model.Message</div>
    }
</div>
