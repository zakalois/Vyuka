@page
@model Vyuka.Pages.Admin.Students.OverviewModel

<h2 class="mb-4">Přehled studentů</h2>

<style>
    .parent-cell {
        min-width: 240px;
    }

    .table td {
        vertical-align: middle;
    }

    .table thead th i {
        margin-right: 6px;
    }

    .action-btn {
        width: 34px;
        height: 34px;
        padding: 0;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.15s;
    }

        .action-btn:hover {
            transform: scale(1.08);
            opacity: 0.9;
        }

    .parent-card {
        line-height: 1.35;
        padding: 4px 0;
    }

    .icon-blue {
        color: #0d6efd;
    }

    .icon-green {
        color: #198754;
    }

    .icon-red {
        color: #dc3545;
    }

    .icon-orange {
        color: #fd7e14;
    }

    .icon-gray {
        color: #6c757d;
    }

    .table tbody tr:nth-child(odd) {
        background-color: #fafbff;
    }

    .table tbody tr:nth-child(even) {
        background-color: #ffffff;
    }

    .table tbody tr:hover {
        background-color: #eef3ff;

        .text-brown {
            color: #C19A6B; /* SaddleBrown */
        }
    }
</style>

<select class="form-select w-auto mb-3" onchange="location = this.value;">
    <optgroup label="Filtr">
        <option value="/Admin/Students/Overview" selected="@(Model.Filter == null)">Všichni studenti</option>
        <option value="/Admin/Students/Overview?filter=active" selected="@(Model.Filter == "active")">Aktivní</option>
        <option value="/Admin/Students/Overview?filter=inactive" selected="@(Model.Filter == "inactive")">Neaktivní</option>
    </optgroup>

    <optgroup label="Vybrat studenta">
        @foreach (var s in Model.AllStudents)
        {
            <option value="/Admin/Students/Edit/@s.Id">@s.LastName @s.FirstName</option>
        }
    </optgroup>
</select>

<table class="table table-hover align-middle">
    <thead style="background-color:#f0f4ff; border-bottom:2px solid #0d6efd;">
        <tr>
            <th><i class="bi bi-person icon-blue"></i> Student</th>
            <th><i class="bi bi-journal-bookmark icon-orange"></i> Předmět</th>
            <th><i class="bi bi-people icon-red"></i> Rodič</th>
            <th><i class="bi bi-cash-coin icon-green"></i> Uhrazené</th>
            <th><i class="bi bi-book icon-blue"></i> Odučené</th>
            <th><i class="bi bi-hourglass-split icon-orange"></i> Zbývá</th>
            <th><i class="bi bi-check2-circle icon-green"></i> Stav</th>
            <th class="text-center"><i class="bi bi-gear icon-gray"></i></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var s in Model.Students)
        {
            <tr>

                <!-- STUDENT -->
                <td>
                    <div class="fw-bold">
                        <i class="bi bi-person-circle icon-blue"></i>
                        @s.LastName @s.FirstName
                    </div>
                </td>

                <!-- PŘEDMĚT -->
                <td>
                    <i class="bi bi-journal-text icon-orange"></i>
                    @s.Subject
                </td>

                <!-- RODIČ -->
                <td class="parent-cell">
                    @if (!string.IsNullOrWhiteSpace(s.ParentLastName))
                    {
                        <div class="parent-card">
                            <div class="fw-bold">
                                <i class="bi bi-person-hearts icon-red"></i>
                                @s.ParentLastName @s.ParentFirstName
                            </div>

                            <div class="text-muted small">
                                <i class="bi bi-envelope icon-blue"></i>
                                <a href="mailto:@s.ParentEmail">@s.ParentEmail</a>
                            </div>

                            <div class="text-muted small">
                                <i class="bi bi-telephone icon-green"></i>
                                <a href="tel:@s.ParentPhone">@s.ParentPhone</a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <span class="text-muted small">
                            <i class="bi bi-dash-circle icon-gray"></i> Bez rodiče
                        </span>
                    }
                </td>

                <!-- UHRAZENÉ -->
                <td>
                    <span class="fw-bold">@s.PaidHours h</span>
                </td>

                <!-- ODUČENÉ -->
                <td>
                    <span>@s.TaughtHours h</span>
                </td>

                <!-- ZBÝVÁ -->
                <td>
                    <span class="fw-bold @(s.RemainingHours <= 2 ? "text-danger" : s.RemainingHours <= 5 ? "text-brown" : "text-success")">
                        @s.RemainingHours h
                    </span>

                </td>

                <!-- STAV -->
                <td class="text-center">
                    @if (s.IsActive)
                    {
                        <span class="fw-bold text-success">
                            <i class="bi bi-check-circle-fill"></i> Aktivní
                        </span>
                    }
                    else
                    {
                        <span class="fw-bold text-danger">
                            <i class="bi bi-x-circle-fill"></i> Neaktivní
                        </span>
                    }
                </td>

                <!-- AKCE -->
                <td class="text-center">
                    <div class="d-flex justify-content-center gap-2">

                        <!-- Upravit -->
                        <a asp-page="/Admin/Students/Edit" asp-route-id="@s.Id"
                           class="btn btn-outline-primary action-btn"
                           title="Upravit studenta">
                            <i class="bi bi-pencil-square"></i>
                        </a>

                        <!-- Aktivovat / deaktivovat -->
                        @if (s.IsActive)
                        {
                            <a asp-page="/Admin/Students/ToggleActive" asp-route-id="@s.Id"
                               class="btn btn-outline-danger action-btn"
                               title="Deaktivovat studenta">
                                <i class="bi bi-person-dash"></i>
                            </a>
                        }
                        else
                        {
                            <a asp-page="/Admin/Students/ToggleActive" asp-route-id="@s.Id"
                               class="btn btn-outline-success action-btn"
                               title="Aktivovat studenta">
                                <i class="bi bi-person-check"></i>
                            </a>
                        }

                    </div>
                </td>

            </tr>
        }
    </tbody>
</table>
