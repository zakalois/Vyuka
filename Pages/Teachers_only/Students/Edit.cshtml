@page "/Teachers_only/Students/Edit/{id:int}"
@model Vyuka.Pages.Teachers_only.Students.EditModel

<h2>Upravit studenta</h2>

<form method="post">

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="row">

        <!-- STUDENT -->
        <div class="col-md-6 mb-3">
            <label>Jméno</label>
            <input asp-for="Student.FirstName" class="form-control" />
            <span asp-validation-for="Student.FirstName" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Příjmení</label>
            <input asp-for="Student.LastName" class="form-control" />
            <span asp-validation-for="Student.LastName" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Email</label>
            <input asp-for="Student.Email" class="form-control" />
            <span asp-validation-for="Student.Email" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Telefon</label>
            <input asp-for="Student.Phone" class="form-control" />
            <span asp-validation-for="Student.Phone" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Předmět</label>
            <select asp-for="Student.SubjectId" asp-items="@(new SelectList(Model.Subjects, "Id", "Name"))" class="form-select"></select>
            <span asp-validation-for="Student.SubjectId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Úroveň</label>
            <input asp-for="Student.Level" class="form-control" />
            <span asp-validation-for="Student.Level" class="text-danger"></span>
        </div>

        <div class="col-md-12 mb-3">
            <label>Poznámka</label>
            <textarea asp-for="Student.Note" class="form-control"></textarea>
            <span asp-validation-for="Student.Note" class="text-danger"></span>
        </div>

        <!-- RODIČ -->
        <h4 class="mt-4">Rodič</h4>

        <div class="col-md-6 mb-3">
            <label>Jméno rodiče</label>
            <input asp-for="Parent.Name" class="form-control" />
            <span asp-validation-for="Parent.Name" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Email rodiče</label>
            <input asp-for="Parent.Email" class="form-control" />
            <span asp-validation-for="Parent.Email" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Telefon rodiče</label>
            <input asp-for="Parent.Phone" class="form-control" />
            <span asp-validation-for="Parent.Phone" class="text-danger"></span>
        </div>

        <div class="col-md-12 mb-3">
            <label>Poznámka rodiče</label>
            <textarea asp-for="Parent.Note" class="form-control"></textarea>
            <span asp-validation-for="Parent.Note" class="text-danger"></span>
        </div>

    </div>

    <button type="submit" class="btn btn-primary">Uložit změny</button>
    <a asp-page="/Teachers_only/Students/Index" class="btn btn-secondary">Zpět</a>

</form>
