@page
@model Vyuka.Pages.Account.EditProfileModel
@{
    ViewData["Title"] = "Upravit profil";
}

<div class="edit-wrapper">

    <div class="edit-card">

        <h2>Upravit profil</h2>

        <form method="post">

            <div class="form-group">
                <label>Jméno</label>
                <input type="text" class="form-control" asp-for="Input.Name" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" class="form-control" asp-for="Input.Email" />
            </div>

            <div class="form-group">
                <label>Role</label>
                <input type="text" class="form-control" asp-for="Input.Role" readonly />
            </div>

            <button type="submit" class="btn btn-primary">Uložit změny</button>
            <a href="/Account/Profile" class="btn btn-secondary">Zpět na profil</a>

        </form>

    </div>

</div>

<style>
    .edit-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 40px;
    }

    .edit-card {
        background: #fff;
        padding: 30px;
        border-radius: 12px;
        width: 500px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ccc;
    }

    .btn {
        padding: 10px 18px;
        border-radius: 6px;
        text-decoration: none;
        color: white;
        font-weight: 600;
        margin-right: 10px;
    }

    .btn-primary { background: #007bff; }
    .btn-secondary { background: #6c757d; }
</style>
