@page
@model Vyuka.Pages.Subjects.CreateModel

<h1>Přidat nový předmět</h1>

<form method="post" enctype="multipart/form-data" id="subjectForm">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-3">
        <label>Obrázek předmětu</label>
        <input type="file" name="ImageFile" class="form-control" onchange="showPreview(this)" />
        <img id="preview" class="image-preview mt-2" style="max-width: 200px; display: none;" />
    </div>

    <div class="mb-3">
        <label class="form-label">Název</label>
        <input asp-for="Subject.Name" class="form-control" />
        <span asp-validation-for="Subject.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Témata</label>

        <div id="topics-container"></div>

        <button type="button" id="add-topic" class="btn btn-secondary mt-2">+ Přidat téma</button>

        <!-- Skryté pole pro uložení témat -->
        <textarea asp-for="Subject.Topics" id="topics-hidden" hidden></textarea>
    </div>

    <button type="submit" class="btn btn-success">Uložit</button>
    <a asp-page="Index" class="btn btn-secondary">Zpět</a>
</form>

@section Scripts {
    <script>
        // Přidání nového řádku
        document.getElementById("add-topic").addEventListener("click", function () {
            const container = document.getElementById("topics-container");

            const row = document.createElement("div");
            row.className = "input-group mb-2";

            row.innerHTML = `
                <input type="text" class="form-control topic-input" placeholder="Napište téma..." />
                <button type="button" class="btn btn-danger remove-topic">X</button>
            `;

            container.appendChild(row);
        });

        // Odebrání řádku
        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("remove-topic")) {
                e.target.parentElement.remove();
            }
        });

        // Před odesláním formuláře uložíme témata
        document.getElementById("subjectForm").addEventListener("submit", function () {
            const inputs = document.querySelectorAll(".topic-input");
            const hidden = document.getElementById("topics-hidden");

            let lines = [];
            inputs.forEach(i => {
                if (i.value.trim() !== "") {
                    lines.push(i.value.trim());
                }
            });

            hidden.value = lines.join("\n");
        });

        // Náhled obrázku
                function showPreview(input) {
            const preview = document.getElementById("preview");
            const file = input.files[0];

            if (file) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src = e.target.result;
                    preview.style.display = "block"; // ⭐ zobrazíme obrázek
                };
                reader.readAsDataURL(file);
            }
        }

    </script>
}
