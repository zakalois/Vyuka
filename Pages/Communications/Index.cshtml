@page
@model Vyuka.Pages.Communications.IndexModel

<h2 class="mb-4">E‑mailová komunikace</h2>

<div class="card shadow-sm">
    <div class="card-body">

        <form method="post">

            <!-- Student -->
            <div class="mb-3">
                <label class="form-label fw-bold">Student</label>
                <select asp-for="SelectedStudentId" class="form-select">
                    <option value="">-- vyberte studenta --</option>
                    @foreach (var s in Model.Students)
                    {
                        <option value="@s.Id">@s.LastName @s.FirstName</option>
                    }
                </select>
            </div>

            <!-- Šablona -->
            <div class="mb-3">
                <label class="form-label fw-bold">Šablona</label>
                <select asp-for="SelectedTemplate" class="form-select">
                    @foreach (var t in Model.Templates)
                    {
                        <option value="@t.Name">@t.Name</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Komu odeslat</label>
                <select asp-for="RecipientType" class="form-select">
                    <option value="student">Studentovi</option>
                    <option value="parent">Rodiči</option>
                    <option value="both">Oběma</option>
                </select>
            </div>


            <!-- Dynamická částka -->
            <div class="mb-3">
                <label class="form-label fw-bold">Částka (Kč)</label>
                <input asp-for="PaymentAmount" class="form-control" />
            </div>

            <!-- Zpráva -->
            <div class="mb-3">
                <label class="form-label fw-bold">Zpráva pro příjemce</label>
                <input asp-for="PaymentMessage" class="form-control" />
            </div>

            <!-- Tlačítka -->
            <button type="submit" formaction="?handler=Preview" class="btn btn-primary">Náhled</button>
            <button type="submit" formaction="?handler=Send" class="btn btn-success">Odeslat</button>

        </form>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.PreviewHtml))
{
    <div class="card shadow-sm mt-4">
        <div class="card-header fw-bold">Náhled</div>
        <div class="card-body">
            @Html.Raw(Model.PreviewHtml)
        </div>
    </div>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-info mt-3">@TempData["Message"]</div>
}
