@page
@model Vyuka.Pages.StudentPortal.LessonsModel

<div class="container mt-4">

    <h2>Moje hodiny – @Model.StudentName</h2>

    <div class="row text-center mb-4 mt-4">

        <div class="col-md-4">
            <div class="p-3 rounded" style="background:#e3f2fd;">
                <h5>Předplacené hodiny</h5>
                <h3>@Model.PrepaidHours.ToString("0.0") h</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-3 rounded" style="background:#e8f5e9;">
                <h5>Odučené hodiny</h5>
                <h3>@Model.TaughtHours.ToString("0.0") h</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-3 rounded" style="background:#fff3e0;">
                <h5>Zůstatek</h5>
                <h3>@Model.Balance.ToString("0.0") h</h3>
            </div>
        </div>

    </div>

    @if (Model.NextLesson != null)
    {
        <div class="mb-4 text-center p-3 rounded"
             style="background:#ffebee; color:#c62828; font-size:1.2rem; font-weight:600;">
            Nejbližší plánovaná hodina:
            <strong>@Model.NextLesson.Date.ToString("dd.MM.yyyy")</strong>,
            @Model.NextLesson.Subject,
            @Model.NextLesson.Hours.ToString("0.0") h
        </div>
    }

    <h4 class="mt-4 mb-3">Plánované a odučené hodiny</h4>

    <table class="table table-bordered table-striped">
        <thead class="table-light">
            <tr>
                <th>Datum</th>
                <th>Předmět</th>
                <th>Téma</th>
                <th>Hodin</th>
                <th>Typ</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var row in Model.Lessons)
            {
                var bg = row.Type == "Plánovaná" ? "#fffde7" : "#e8f5e9";

                <tr style="background:@bg;">
                    <td>@row.Date.ToString("dd.MM.yyyy")</td>
                    <td>@row.Subject</td>
                    <td>@row.Topic</td>
                    <td>@row.Hours.ToString("0.0")</td>
                    <td>@row.Type</td>
                </tr>
            }
        </tbody>
    </table>

</div>
