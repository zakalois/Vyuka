@using Microsoft.AspNetCore.Identity
@inject UserManager<Vyuka.Models.AppUser> UserManager
@inject SignInManager<Vyuka.Models.AppUser> SignInManager


<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Teacher Panel</title>

    <!-- BOOTSTRAP + IKONY + TVÉ CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>

    <!-- HLAVIČKA -->
    <header class="admin-header d-flex justify-content-between align-items-center px-4 py-3">
        <div class="fw-bold admin-title">
            Teacher – Výuka
        </div>

        <div>
            <button id="darkToggle" class="btn btn-sm admin-dark-btn">
                Tmavý režim
            </button>
        </div>
    </header>

    <!-- MENU -->
    <nav class="admin-menu px-4 py-2">
        <div class="d-flex align-items-center gap-3">

            <a asp-page="/Teachers_only/Dashboard" class="nav-link">Dashboard</a>
            <a asp-page="/Teachers_only/Students" class="nav-link">Moji studenti</a>
            <a asp-page="/Teachers_only/Lessons" class="nav-link">Moje hodiny</a>
            <a asp-page="/Teachers_only/Schedule" class="nav-link">Rozvrh</a>

            <!-- LOGOUT VPRAVO -->
            <form method="post" asp-page="/Logout" class="ms-auto">
                <button type="submit" class="btn btn-link nav-link p-0">
                    <i class="bi bi-box-arrow-right"></i> Odhlásit se
                </button>
            </form>

        </div>
    </nav>

    <!-- OBSAH STRÁNKY -->
    <main class="container mt-4">
        @RenderBody()
    </main>

    <!-- DARK MODE SCRIPT -->
    <script>
            (function () {
                const body = document.body;
                const toggle = document.getElementById('darkToggle');

                const saved = localStorage.getItem('theme');
                if (saved === 'dark') {
                    body.classList.add('dark');
                    toggle.textContent = 'Světlý režim';
                }

                toggle.addEventListener('click', function () {
                    body.classList.toggle('dark');
                    const isDark = body.classList.contains('dark');
                    toggle.textContent = isDark ? 'Světlý režim' : 'Tmavý režim';
                    localStorage.setItem('theme', isDark ? 'dark' : 'light');
                });
            })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
