@page "/Teachers_only/Dashboard"
@model Vyuka.Pages.Teachers_only.DashboardModel

@{
    Layout = "_TeacherLayout";
}

<div class="container mt-4">

    <!-- Horní tři boxy -->
    <div class="row">

        <!-- Dnešní hodiny -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <strong>Dnešní hodiny</strong>
                </div>
                <div class="card-body">
                    @if (Model.TodayLessons.Any())
                    {
                        <ul class="list-group">
                            @foreach (var lesson in Model.TodayLessons)
                            {
                                <li class="list-group-item">
                                    <strong>@lesson.Time</strong> – @lesson.Student (@lesson.Subject)
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p>Nemáte dnes žádné hodiny.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Moji studenti -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <strong>Moji studenti</strong>
                </div>
                <div class="card-body">
                    <p><strong>Celkem:</strong> @Model.StudentCount</p>
                    <p><strong>Nízký kredit:</strong> @Model.LowCreditCount</p>
                </div>
            </div>
        </div>

        <!-- Upozornění -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-danger text-white">
                    <strong>Upozornění</strong>
                </div>
                <div class="card-body">
                    @if (Model.Notifications.Any())
                    {
                        <ul class="list-group">
                            @foreach (var note in Model.Notifications)
                            {
                                <li class="list-group-item">@note</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p>Žádná upozornění.</p>
                    }
                </div>
            </div>
        </div>

    </div>

    <!-- Týdenní rozvrh přes celou šířku -->
    <div class="card bg-warning mt-4">
        <div class="card-header">
            <strong>Týdenní rozvrh</strong>
        </div>

        <div class="card-body">
            <div class="schedule-grid">

                @foreach (var day in Model.WeeklySchedule)
                {
                    <div class="day-column">
                        <div class="day-header">
                            <strong>@day.Day</strong><br />
                            <small class="text-muted">@day.Date.ToString("dd.MM.")</small><br />
                            <span class="text-muted">
                                @day.Lessons.Sum(l => (l.End - l.Start).TotalHours) hodin
                            </span>
                        </div>

                        <hr />
                        @if (day.Lessons.Any())
                        {
                            foreach (var l in day.Lessons)
                            {
                                <div class="lesson-block @(l.IsTaught ? "taught" : "")">
                                    <div class="lesson-body">

                                        <strong>@l.Student.LastName @l.Student.FirstName</strong><br />

                                        @if (l.SubjectTopic != null)
                                        {
                                            <span class="text-muted">@l.SubjectTopic.Name</span><br />
                                        }

                                        <span class="text-muted">@l.Subject.Name</span><br />
                                        @l.Start.ToString(@"hh\:mm") – @l.End.ToString(@"hh\:mm")<br />

                                        @if (!string.IsNullOrEmpty(l.MeetLink))
                                        {
                                            <a href="@l.MeetLink" target="_blank" class="meet-link">Meet</a>
                                        }

                                    </div>
                                </div>
                            }
                        }

                        else
                        {
                            <div class="text-muted small">Žádné hodiny</div>
                        }
                    </div>
                }

            </div>
        </div>
    </div>

