@page
@model Vyuka.Pages.Dashboard.AdminModel
@using Microsoft.AspNetCore.Http


@{
    Layout = null;
    ViewData["Title"] = "Řídicí panel Administrátora";

    var userName = !string.IsNullOrEmpty(User.Identity?.Name)
        ? User.Identity.Name
        : "Přihlášený uživatel";

    var userRole = HttpContext.Session.GetString("UserRole") ?? "Role neznámá";
}

<style>
    /* ---------------------------------------------------------
           BARVY – AUTOMATICKY SE MĚNÍ PODLE REŽIMU
        --------------------------------------------------------- */
    :root {
        --bg: #f1f5f9;
        --text: #1e293b;
        --white: #ffffff;
        --primary: #1e3a8a;
        --primary-light: #3b82f6;
        --border: #d1d5db;
        --box-bg: #ffffff;
    }

    body.dark {
        --bg: #0f172a;
        --text: #f8fafc;
        --white: #1e293b;
        --primary: #60a5fa;
        --primary-light: #93c5fd;
        --border: #1f2937;
        --box-bg: #020617;
    }

    body {
        margin: 0;
        font-family: "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        transition: 0.3s;
    }

    /* ---------------------------------------------------------
           HLAVIČKA + MENU
        --------------------------------------------------------- */
    header {
        background: var(--primary);
        color: white;
        padding: 14px 28px;
        font-size: 20px;
        font-weight: 600;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .top-menu {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
    }

        .top-menu a {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: white;
            text-decoration: none;
            font-weight: 600;
            padding: 6px 10px;
            border-radius: 6px;
            transition: 0.2s;
            font-size: 14px;
        }

            .top-menu a:hover {
                background: var(--primary-light);
            }

        .top-menu .icon {
            font-size: 16px;
        }

    .dark-toggle {
        background: var(--primary-light);
        color: white;
        padding: 8px 14px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        border: none;
        font-size: 14px;
    }

    /* ---------------------------------------------------------
           OBSAH
        --------------------------------------------------------- */
    .container {
        max-width: 1200px;
        margin: 28px auto;
        padding: 0 20px;
    }

    .user-kpi-row {
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 30px;
        align-items: center;
        margin-bottom: 32px;
    }

    .profile-inline {
        text-align: center;
        background: var(--box-bg);
        padding: 20px;
        border-radius: 12px;
        border: 1px solid var(--border);
    }

        .profile-inline img {
            width: 110px;
            height: 110px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid var(--primary-light);
        }

        .profile-inline .profile-name {
            margin-top: 10px;
            font-size: 18px;
            font-weight: 700;
            color: var(--text);
        }

        .profile-inline .profile-role {
            margin-top: 4px;
            font-size: 14px;
            font-weight: 600;
            opacity: 0.8;
            color: var(--primary-light);
        }

        .profile-inline .logout-link {
            margin-top: 10px;
            font-size: 14px;
            font-weight: 600;
        }

            .profile-inline .logout-link a {
                color: var(--primary-light);
                text-decoration: none;
            }

                .profile-inline .logout-link a:hover {
                    color: var(--primary);
                }

    .kpi-inline-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .kpi-box {
        background: var(--box-bg);
        padding: 24px;
        border-radius: 12px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.15);
        text-align: center;
        border: 1px solid var(--border);
    }

    .kpi-title {
        font-size: 13px;
        opacity: 0.7;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text);
    }

    .kpi-value {
        font-size: 30px;
        font-weight: 700;
        margin-top: 8px;
        color: var(--text);
    }

    .kpi-sub {
        font-size: 16px;
        margin-top: 4px;
        opacity: 0.85;
        color: var(--text);
    }

    .actions {
        margin-bottom: 32px;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .btn {
        background: var(--primary-light);
        color: white;
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.2s;
        font-size: 14px;
        border: 1px solid var(--primary-light);
    }

        .btn:hover {
            background: var(--primary);
            border-color: var(--primary);
        }

    /* ---------------------------------------------------------
           GOOGLE SLUŽBY – BOXY
        --------------------------------------------------------- */
    .online-box {
        background: var(--box-bg);
        padding: 22px;
        border-radius: 12px;
        border: 1px solid var(--border);
        margin-bottom: 24px;
    }

    .google-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 14px;
        margin-top: 10px;
        margin-bottom: 10px;
    }

    .google-item {
        background: var(--white);
        border-radius: 10px;
        padding: 12px 8px;
        text-align: center;
        text-decoration: none;
        color: var(--text);
        font-size: 13px;
        font-weight: 600;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        border: 1px solid var(--border);
        transition: 0.2s;
    }

        .google-item:hover {
            background: var(--primary-light);
            color: white;
            border-color: var(--primary-light);
        }

        .google-item img {
            width: 28px;
            height: 28px;
            display: block;
        }

    .online-note {
        font-size: 13px;
        color: var(--text);
        opacity: 0.7;
        text-align: center;
        margin-top: 6px;
    }
</style>

<header>
    <div class="header-left">
        Řídicí panel Administrátora

        <!--
<nav class="top-menu">
    <a href="/Dashboard/Admin"><span class="icon">🏠</span>Dashboard</a>
    <a href="/Students"><span class="icon">👨‍🎓</span>Studenti</a>
    <a href="/Schedule"><span class="icon">📅</span>Rozvrh</a>
    <a href="/Lessons"><span class="icon">📘</span>Hodiny</a>
    <a href="/Payments"><span class="icon">💰</span>Finance</a>
    <a href="/Communications"><span class="icon">✉️</span>E‑maily</a>
</nav>
-->

    </div>

    <button id="darkToggle" class="dark-toggle" type="button">Tmavý režim</button>
</header>

<div class="container">

    <div class="user-kpi-row">
        
        <div class="profile-inline">
            <img src="/images/profile-user.jpg" alt="Profil">
            <div class="profile-name">@userName</div>
            <div class="profile-role">@userRole</div>

            <div class="logout-link">
                <a href="/Logout">Odhlásit se</a>
            </div>
        </div>

        <div class="kpi-inline-grid">
            <div class="kpi-box">
                <div class="kpi-title">Studenti</div>
                <div class="kpi-value">24</div>
            </div>

            <div class="kpi-box">
                <div class="kpi-title">Hodiny tento týden</div>
                <div class="kpi-value">8</div>
            </div>

            <div class="kpi-box">
                <div class="kpi-title">Nejbližší lekce</div>
                <div class="kpi-value">
                    @(Model.NextLessonDate?.ToString("d. MMMM") ?? "Žádná lekce")
                </div>
                <div class="kpi-sub">
                    @(Model.NextLessonDate?.ToString("HH:mm") ?? "")
                </div>
            </div>
        </div>

    </div>

    <div class="actions">
        <a class="btn" href="/Students/Create">Přidat studenta</a>
        <a class="btn" href="/Students">Studenti</a>
        <a class="btn" href="/Schedule">Rozvrh</a>
        <a class="btn" href="/Lessons">Hodiny</a>
        <a class="btn" href="/Offers/Create">Vytvořit nabídku</a>
        <a class="btn" href="/Payments/Index">Finance</a>

        <div>
            <form method="post" asp-page-handler="Backup" style="display:inline;">
                <button type="submit" class="btn btn-green">
                    💾 Zálohovat databázi
                </button>
            </form>
        </div>
    </div>


    <div class="online-box">
        <h3>Online služby</h3>

        <div class="google-grid">
            <a class="google-item" href="https://mail.google.com" target="_blank">
                <img src="https://www.gstatic.com/images/branding/product/1x/gmail_48dp.png">
                Gmail
            </a>

            <a class="google-item" href="https://calendar.google.com" target="_blank">
                <img src="https://www.gstatic.com/images/branding/product/1x/calendar_48dp.png">
                Kalendář
            </a>

            <a class="google-item" href="https://meet.google.com" target="_blank">
                <img src="https://www.gstatic.com/images/branding/product/1x/meet_48dp.png">
                Meet
            </a>

            <a class="google-item" href="https://drive.google.com" target="_blank">
                <img src="https://www.gstatic.com/images/branding/product/1x/drive_48dp.png">
                Drive
            </a>

            <a class="google-item" href="https://web.whatsapp.com" target="_blank">
                <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg">
                WhatsApp
            </a>

            <a class="google-item" href="/Communications">
                <img src="https://upload.wikimedia.org/wikipedia/commons/4/4e/Mail_%28iOS%29.svg">
                E‑maily
            </a>
        </div>

        <div class="online-note">
            Všechny služby se otevřou v novém okně.
            E‑mailová komunikace se otevře zde v aplikaci.
        </div>
    </div>

</div>

<script>
    (function () {
        const body = document.body;
        const toggle = document.getElementById('darkToggle');

        // načtení uloženého režimu
        const saved = localStorage.getItem('theme');

        if (saved === 'light') {
            body.classList.add('light');
            toggle.textContent = 'Tmavý režim';
        } else {
            body.classList.add('dark');
            toggle.textContent = 'Světlý režim';
        }

        toggle.addEventListener('click', function () {
            if (body.classList.contains('dark')) {
                body.classList.remove('dark');
                body.classList.add('light');
                toggle.textContent = 'Tmavý režim';
                localStorage.setItem('theme', 'light');
            } else {
                body.classList.remove('light');
                body.classList.add('dark');
                toggle.textContent = 'Světlý režim';
                localStorage.setItem('theme', 'dark');
            }
        });
    })();
</script>
