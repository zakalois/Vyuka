@page
@model LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
    ViewData["Title"] = "Přihlášení";
}

<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Přihlášení</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <div class="container mt-5" style="max-width: 400px;">
        <h2 class="mb-4 text-center">Přihlášení</h2>

        <form method="post">

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" asp-for="Email" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Heslo</label>
                <input type="password" asp-for="Password" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-primary w-100">Přihlásit</button>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
            }

            <div class="mt-3 text-center">
                <a href="/Account/ForgotPassword">Zapomenuté heslo?</a>
            </div>

        </form>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
