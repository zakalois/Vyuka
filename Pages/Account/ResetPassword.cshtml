@page "{token?}"
@model Vyuka.Pages.Account.ResetPasswordModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<div class="container mt-5" style="max-width: 400px;">
    <h2 class="mb-4 text-center">Reset hesla</h2>

    <form method="post">

        <input type="hidden" asp-for="Token" />

        <div class="mb-3">
            <label class="form-label">Nové heslo</label>
            <input type="password" asp-for="NewPassword" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Potvrzení hesla</label>
            <input type="password" asp-for="ConfirmPassword" class="form-control" required />
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }

        <button type="submit" class="btn btn-primary w-100">Změnit heslo</button>
    </form>
</div>
