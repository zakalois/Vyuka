@page "/Admin/Students"
@model Vyuka.Pages.Admin.Students.IndexModel

<style>
    .row-pink {
        background-color: #f8d7da !important;
    }
</style>

<h1>Seznam studentů</h1>

<div class="d-grid mb-3">
    <a class="btn btn-primary btn-lg w-100" asp-page="Create">
        Přidat studenta
    </a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Příjmení</th>
            <th>Jméno</th>
            <th>Věk</th>
            <th>Email</th>
            <th>Telefon</th>

            <th>Rodič</th>

            <th>Učitel</th>

            <th class="text-center" style="width:110px;">Akce</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Students)
        {
            var parent = Model.Parents.FirstOrDefault(p => p.StudentId == item.Id);

            <tr class="@(item.IsActive ? "" : "row-pink")">

                <td>@item.LastName</td>
                <td>@item.FirstName</td>
                <td>@item.Age</td>
                <td>@item.Email</td>
                <td>@item.Phone</td>

                <!-- ⭐ NOVÝ BLOK PRO RODIČE -->
                <td>
                    @if (parent != null)
                    {
                        <div data-bs-toggle="tooltip" title="Jméno rodiče">
                            <i class="bi bi-person"></i> @parent.Name
                        </div>

                        @if (!string.IsNullOrEmpty(parent.Phone))
                        {
                            <div data-bs-toggle="tooltip" title="Telefon rodiče">
                                <i class="bi bi-telephone"></i> @parent.Phone
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(parent.Email))
                        {
                            <div data-bs-toggle="tooltip" title="Email rodiče">
                                <i class="bi bi-envelope"></i> @parent.Email
                            </div>
                        }
                    }
                    else
                    {
                        <span class="text-muted">Neuveden</span>
                    }
                </td>

                <!-- UČITEL -->
                <td class="teacher-cell @(item.TeacherId == null ? "no-teacher" : "has-teacher")">
                    @if (item.Teacher != null)
                    {
                        <span title="@item.Teacher.User?.Email">
                            @item.Teacher.FullName
                        </span>
                    }
                    else
                    {
                        <span class="text-dark">
                            <i class="bi bi-exclamation-circle"></i> Nepřiřazen
                        </span>
                    }
                </td>

                <!-- AKCE -->
                <td class="text-center" style="white-space:nowrap;">

                    <a asp-page="Edit" asp-route-id="@item.Id" class="text-primary me-2" title="Upravit">
                        <i class="bi bi-pencil-square"></i>
                    </a>

                    <a asp-page="Details" asp-route-id="@item.Id" class="text-info me-2" title="Detail">
                        <i class="bi bi-search"></i>
                    </a>

                    <a asp-page="Delete" asp-route-id="@item.Id" class="text-danger me-3" title="Smazat">
                        <i class="bi bi-trash"></i>
                    </a>

                    <a asp-page="/Admin/Students/AssignTeacher"
                       asp-route-id="@item.Id"
                       class="btn btn-outline-dark btn-sm"
                       title="Přiřadit učitele">
                        <i class="bi bi-person-fill-gear"></i>
                    </a>

                </td>

            </tr>
        }
    </tbody>

</table>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    });
</script>
