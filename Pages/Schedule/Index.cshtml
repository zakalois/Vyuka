@page
@using System.Globalization
@model Vyuka.Pages.Schedule.ScheduleIndexModel

<h1>Týdenní rozvrh</h1>

<!-- NAVIGACE TÝDNŮ -->
<div class="d-flex justify-content-between align-items-center mb-4">

    <a class="btn btn-secondary"
           asp-page="./Index"
           asp-route-week="@Model.StartOfWeek.AddDays(-7).ToString("yyyy-MM-dd")">
        ← Předchozí týden
    </a>

    <div class="text-center">
        <h4>@Model.StartOfWeek.ToString("dd.MM.yyyy") – @Model.EndOfWeek.ToString("dd.MM.yyyy")</h4>

        <a class="btn btn-info mt-2"
               asp-page="./Index"
               asp-route-week="@DateTime.Today.ToString("yyyy-MM-dd")">
            Aktuální týden
        </a>
    </div>

    <a class="btn btn-secondary"
           asp-page="./Index"
           asp-route-week="@Model.StartOfWeek.AddDays(7).ToString("yyyy-MM-dd")">
        Další týden →
    </a>

</div>

<!-- FORMULÁŘ PRO PŘIDÁNÍ HODINY -->
@if (Model.EditPlan == null)
{
    <div class="card p-3 mb-4 shadow-sm">
        <h5>Přidat hodinu</h5>

        <form method="post" asp-page-handler="Add">

            <div class="row">
                <div class="col-md-3">
                    <label>Student</label>
                    <select asp-for="NewStudentId" class="form-control">
                        @foreach (var s in Model.Students)
                        {
                            <option value="@s.Id">@s.LastName @s.FirstName</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label>Předmět</label>
                    <select asp-for="NewSubjectId" class="form-select" id="subjectSelect">
                        <option value="">-- Vyber předmět --</option>
                        @foreach (var s in Model.Subjects)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label>Téma</label>
                    <select asp-for="NewTopicId" class="form-select" id="topicSelect">
                        <option value="">-- Vyber téma --</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label>Den</label>
                    <select asp-for="NewDay" class="form-control">
                        <option value="Monday">Pondělí</option>
                        <option value="Tuesday">Úterý</option>
                        <option value="Wednesday">Středa</option>
                        <option value="Thursday">Čtvrtek</option>
                        <option value="Friday">Pátek</option>
                        <option value="Saturday">Sobota</option>
                        <option value="Sunday">Neděle</option>
                    </select>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-3">
                    <label>Začátek</label>
                    <input asp-for="NewStart" type="time" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label>Konec</label>
                    <input asp-for="NewEnd" type="time" class="form-control" />
                </div>

                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check mt-4">
                        <input asp-for="NotifyStudentOnDelete" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" for="NotifyStudentOnDelete">
                            Odeslat zrušení studentovi při smazání lekce
                        </label>
                    </div>
                </div>
            </div>

            <button class="btn btn-primary mt-3">Přidat hodinu</button>

        </form>
    </div>
}
else
{
    <!-- EDITAČNÍ FORMULÁŘ -->
    <div class="card p-3 mb-4 shadow-sm bg-warning-subtle">
        <h5>Upravit hodinu</h5>

        <form method="post" asp-page-handler="Update">

            <input type="hidden" name="id" value="@Model.EditPlan.Id" />

            <div class="row">
                <div class="col-md-3">
                    <label>Student</label>
                    <select name="StudentId" class="form-control">
                        @foreach (var s in Model.Students)
                        {
                            <option value="@s.Id" selected="@(s.Id == Model.EditPlan.StudentId)">
                                @s.LastName @s.FirstName
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label>Předmět</label>
                    <select name="SubjectId" class="form-select">
                        @foreach (var s in Model.Subjects)
                        {
                            <option value="@s.Id" selected="@(s.Id == Model.EditPlan.SubjectId)">
                                @s.Name
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label>Téma</label>
                    <select name="SubjectTopicId" class="form-select">
                        <option value="">-- Vyber téma --</option>
                        @foreach (var t in Model.Topics.Where(t => t.SubjectId == Model.EditPlan.SubjectId))
                        {
                            <option value="@t.Id" selected="@(t.Id == Model.EditPlan.SubjectTopicId)">
                                @t.Name
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label>Začátek</label>
                    <input name="Start" type="time" class="form-control"
                           value="@Model.EditPlan.Start.ToString(@"hh\:mm")" />
                </div>

                <div class="col-md-3 mt-3">
                    <label>Konec</label>
                    <input name="End" type="time" class="form-control"
                           value="@Model.EditPlan.End.ToString(@"hh\:mm")" />
                </div>
            </div>

            <button class="btn btn-success mt-3">Uložit</button>
            <button class="btn btn-secondary mt-3" formmethod="post" formaction="?handler=EditCancel">Zrušit</button>

        </form>
    </div>
}

<!-- TÝDENNÍ ROZVRH -->
<div class="row">

    @for (int i = 0; i < 7; i++)
    {
        var date = Model.StartOfWeek.AddDays(i);

        <div class="col-12 col-md-1 border p-2 text-center" style="min-width: 180px;">

            <strong>
                @(
                    CultureInfo.GetCultureInfo("cs-CZ")
                        .TextInfo
                        .ToTitleCase(date.ToString("dddd", new CultureInfo("cs-CZ")))
                )
            </strong><br />

            @date.ToString("dd.MM.")

            <hr />

            @foreach (var p in Model.Plans.Where(p => p.Date.Date == date.Date))
            {
                var taughtStyle = p.IsTaught
                    ? "opacity:0.7;border-left:4px solid #28a745;"
                    : "";

                <div class="p-2 mb-2 rounded text-start"
                     style="background-color:@Model.GetColorForStudent(p.StudentId);@taughtStyle">

                    <strong>@p.Student.LastName @p.Student.FirstName</strong><br />
                    @p.Subject.Name – @p.SubjectTopic?.Name<br />
                    @p.Start.ToString(@"hh\:mm") – @p.End.ToString(@"hh\:mm")<br />

                    @if (!string.IsNullOrEmpty(p.MeetLink))
                    {
                        <a href="@p.MeetLink" target="_blank">Meet</a><br />
                    }

                    <div class="d-flex flex-row flex-nowrap gap-1 mt-1 align-items-center">

                        @if (!p.IsTaught)
                        {
                            <form method="post" asp-page-handler="Teach" class="m-0 p-0">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button class="btn btn-success btn-sm px-1 py-0"
                                        title="Označit jako odučené">
                                    ✔
                                </button>
                            </form>
                        }

                        <form method="post" asp-page-handler="EditStart" class="m-0 p-0">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button class="btn btn-warning btn-sm px-1 py-0"
                                    title="Upravit lekci">
                                ✏
                            </button>
                        </form>

                        <form method="post" asp-page-handler="Delete" class="m-0 p-0">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button class="btn btn-danger btn-sm px-1 py-0"
                                    title="Smazat lekci">
                                🗑
                            </button>
                        </form>

                    </div>

                </div>
            }
        </div>
    }

</div>

@section Scripts {
    <script>
        document.getElementById("subjectSelect")?.addEventListener("change", function () {
            var subjectId = this.value;

            fetch(`?handler=Topics&subjectId=${subjectId}`)
                .then(response => response.json())
                .then(data => {
                    var topicSelect = document.getElementById("topicSelect");
                    topicSelect.innerHTML = '<option value="">-- Vyber téma --</option>';

                    data.forEach(t => {
                        topicSelect.innerHTML += `<option value="${t.id}">${t.name}</option>`;
                    });
                });
        });
    </script>
}
