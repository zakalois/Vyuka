@page
@model Vyuka.Pages.Payments.IndexModel

<h2>Platby</h2>

<!-- Celkový přehled -->
<div class="row mb-4">

    <div class="col-md-2">
        <div class="alert alert-primary text-center">
            <strong>Studentů:</strong><br />
            @Model.TotalStudents
        </div>
    </div>

    <div class="col-md-2">
        <div class="alert alert-success text-center">
            <strong>Aktivních:</strong><br />
            @Model.ActiveStudents
        </div>
    </div>

    <div class="col-md-2">
        <div class="alert alert-secondary text-center">
            <strong>Neaktivních:</strong><br />
            @Model.InactiveStudents
        </div>
    </div>

    <div class="col-md-2">
        <div class="alert alert-info text-center">
            <strong>Celkem zaplaceno:</strong><br />
            @Model.TotalPaid Kč
        </div>
    </div>

    <div class="col-md-2">
        <div class="alert alert-warning text-center">
            <strong>Předplacené hodiny:</strong><br />
            @Model.TotalPrepaidHours h
        </div>
    </div>

    <div class="col-md-2">
        <div class="alert alert-danger text-center">
            <strong>Odučené hodiny:</strong><br />
            @Model.TotalTaughtHours h
        </div>
    </div>

</div>

<!-- Filtry -->
<form method="get" class="row g-3 mb-4">

    <div class="col-md-4">
        <label class="form-label">Vyber studenta:</label>
        <select asp-for="SelectedStudentId"
                asp-items="Model.StudentList"
                class="form-select"
                onchange="this.form.submit()">
            <option value="0">Všichni studenti</option>
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Od:</label>
        <input asp-for="FromDate" type="date" class="form-control" />
    </div>

    <div class="col-md-3">
        <label class="form-label">Do:</label>
        <input asp-for="ToDate" type="date" class="form-control" />
    </div>

    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary w-100">Filtrovat</button>
    </div>

</form>

<!-- Tlačítko přes celou šířku -->
<div class="mb-4">
    <a asp-page="/Payments/Create" class="btn btn-success w-100 py-2 fs-5">
        ➕ Přidat platbu
    </a>
</div>

@if (Model.SelectedStudentId > 0)
{
    <!-- Přehled studenta -->
    <h3>Přehled studenta</h3>

    <div class="row mb-4">

        <div class="col-md-4">
            <div class="alert alert-primary text-center">
                <strong>Předplacené hodiny:</strong><br />
                @Model.SelectedStudentPrepaidHours h
            </div>
        </div>

        <div class="col-md-4">
            <div class="alert alert-warning text-center">
                <strong>Odučené hodiny:</strong><br />
                @Model.SelectedStudentTaughtHours h
            </div>
        </div>

        <div class="col-md-4">
            <div class="alert alert-info text-center">
                <strong>Zůstatek:</strong><br />
                @Model.SelectedStudentBalance h
            </div>
        </div>

    </div>

    <!-- Platební statistiky -->
    <h3>Platební statistiky studenta</h3>

    <div class="row mb-4">

        <div class="col-md-4">
            <div class="alert alert-success text-center">
                <strong>Celkem zaplaceno:</strong><br />
                @Model.SelectedStudentTotalPaid Kč
            </div>
        </div>

        <div class="col-md-4">
            <div class="alert alert-secondary text-center">
                <strong>Počet plateb:</strong><br />
                @Model.SelectedStudentPaymentCount
            </div>
        </div>

        <div class="col-md-4">
            <div class="alert alert-dark text-center">
                <strong>Poslední platba:</strong><br />
                @Model.SelectedStudentLastPaymentDate?.ToShortDateString() <br />
                @Model.SelectedStudentLastPaymentAmount Kč — @Model.SelectedStudentLastPaymentHours h
            </div>
        </div>

    </div>
}

<!-- Tabulka plateb -->
@if (!Model.Payments.Any())
{
    <p class="text-muted">Žádné platby nenalezeny.</p>
}
else
{
    <table class="table table-bordered text-center">
        <thead>
            <tr>
                <th>Datum</th>
                <th class="text-start">Student</th>
                <th>Částka</th>
                <th>Předplacené hodiny</th>
                <th>Cena za hodinu</th>
                <th>Způsob platby</th>
                <th>Poznámka</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Payments)
            {
                <tr>
                    <td>@p.Date.ToShortDateString()</td>
                    <td class="text-start">@p.Student.LastName @p.Student.FirstName</td>
                    <td>@p.Amount Kč</td>
                    <td>@p.HoursPurchased</td>
                    <td>@p.PricePerHour Kč</td>
                    <td>@p.Method</td>
                    <td>@p.Note</td>
                </tr>
            }
        </tbody>
    </table>
}
