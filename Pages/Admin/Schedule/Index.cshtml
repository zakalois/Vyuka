@page "/Admin/Schedule"
@model Vyuka.Pages.Admin.Schedule.IndexModel
@using System.Globalization
@using Vyuka.Extensions <!-- 🔥 TADY JE OPRAVA -->

@if (Model.StartOfWeek == default(DateTime) || Model.EndOfWeek == default(DateTime))
{
    <p>Načítám…</p>
    return;
}

@{
    var safeStart = Model.StartOfWeek;
    var safeEnd = Model.EndOfWeek;
}

<h1>Týdenní rozvrh</h1>


<div class="d-flex justify-content-between align-items-center mb-4">

    <a class="btn btn-secondary"
       asp-page="./Index"
       asp-route-week="@safeStart.AddDays(-7).ToString("yyyy-MM-dd")"
       asp-route-TeacherId="@Model.TeacherId">
        ← Předchozí týden
    </a>

    <div class="text-center">
        <h4>@safeStart.ToString("dd.MM.yyyy") – @safeEnd.ToString("dd.MM.yyyy")</h4>

        <a class="btn btn-info mt-2"
           asp-page="./Index"
           asp-route-week="@DateTime.Today.StartOfWeek(DayOfWeek.Monday).ToString("yyyy-MM-dd")"
           asp-route-TeacherId="@Model.TeacherId">
            Aktuální týden
        </a>
    </div>

    <a class="btn btn-secondary"
       asp-page="./Index"
       asp-route-week="@safeStart.AddDays(7).ToString("yyyy-MM-dd")"
       asp-route-TeacherId="@Model.TeacherId">
        Další týden →
    </a>

</div>



@if (Model.EditPlan == null)
{
    <div class="card p-3 mb-4 shadow-sm">

        <h5>Přidat hodinu</h5>

        <form method="post" asp-page-handler="Add">

            <input type="hidden" asp-for="Week" />

            <!-- ŘÁDEK 1: UČITEL – STUDENT – PŘEDMĚT – TÉMA -->
            <div class="row mb-3">

                <!-- UČITEL -->
                <div class="col-md-3">
                    <label class="form-label fw-bold">Učitel</label>

                    <select asp-for="TeacherId" class="form-select">
                        <option value="">-- Administrator --</option>

                        @foreach (var t in Model.AllTeachers)
                        {
                            <option value="@t.Id" selected="@(t.Id == Model.TeacherId)">
                                @t.Name (@t.Email)
                            </option>
                        }
                    </select>

                    <!-- Hidden input musí být mimo select -->
                    <input type="hidden" asp-for="TeacherId" />
                </div>

                <!-- STUDENT -->
                <div class="col-md-3">
                    <label class="form-label fw-bold">Student</label>
                    <select asp-for="NewStudentId" class="form-select">
                        @foreach (var s in Model.Students)
                        {
                            <option value="@s.Id">@s.LastName @s.FirstName</option>
                        }
                    </select>
                </div>

                <!-- PŘEDMĚT -->
                <div class="col-md-3">
                    <label class="form-label fw-bold">Předmět</label>
                    <select asp-for="NewSubjectId" class="form-select" id="subjectSelect">
                        <option value="">-- Vyber předmět --</option>
                        @foreach (var s in Model.Subjects)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>

                <!-- TÉMA -->
                <div class="col-md-3">
                    <label class="form-label fw-bold">Téma</label>
                    <select asp-for="NewTopicId" class="form-select" id="topicSelect">
                        <option value="">-- Vyber téma --</option>
                    </select>
                </div>

            </div>

            <!-- ŘÁDEK 2: DATUM – ZAČÁTEK – KONEC -->
            <div class="row mb-3">

                <div class="col-md-4">
                    <label class="form-label fw-bold">Datum lekce</label>
                    <input asp-for="NewDate" type="date" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Začátek</label>
                    <input asp-for="NewStart" type="time" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Konec</label>
                    <input asp-for="NewEnd" type="time" class="form-control" />
                </div>

            </div>

            <button class="btn btn-success w-100 py-2 fs-5">Přidat hodinu</button>

        </form>

    </div>
}
else
{
    <!-- EDITAČNÍ FORMULÁŘ -->
    <div class="card p-3 mb-4 shadow-sm bg-warning-subtle">
        <h5>Upravit hodinu</h5>

        <form method="post" asp-page-handler="Update">

            <input type="hidden" name="Week" value="@Model.Week.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="id" value="@Model.EditPlan.Id" />

            <div class="row">

                <!-- STUDENT -->
                <div class="col-md-3">
                    <label>Student</label>
                    <select name="StudentId" class="form-control">
                        @foreach (var s in Model.Students)
                        {
                            <option value="@s.Id"
                                    selected="@(s.Id == Model.EditPlan.StudentId)">
                                @s.LastName @s.FirstName
                            </option>
                        }
                    </select>
                </div>

                <!-- PŘEDMĚT -->
                <div class="col-md-3">
                    <label>Předmět</label>
                    <select name="SubjectId" class="form-select">
                        @foreach (var s in Model.Subjects)
                        {
                            <option value="@s.Id"
                                    selected="@(s.Id == Model.EditPlan.SubjectId)">
                                @s.Name
                            </option>
                        }
                    </select>
                </div>

                <!-- TÉMA -->
                <div class="col-md-3">
                    <label>Téma</label>
                    <select name="SubjectTopicId" class="form-select">
                        <option value="">-- Vyber téma --</option>
                        @foreach (var t in Model.Topics.Where(t => t.SubjectId == Model.EditPlan.SubjectId))
                        {
                            <option value="@t.Id"
                                    selected="@(t.Id == Model.EditPlan.SubjectTopicId)">
                                @t.Name
                            </option>
                        }
                    </select>
                </div>

                <!-- DATUM LEKCE -->
                <div class="col-md-3">
                    <label>Datum lekce</label>
                    <input name="Date"
                           type="date"
                           class="form-control"
                           value="@Model.EditPlan.Date.ToString("yyyy-MM-dd")" />
                </div>

                <!-- ZAČÁTEK -->
                <div class="col-md-3 mt-3">
                    <label>Začátek</label>
                    <input name="Start"
                           type="time"
                           class="form-control"
                           value="@Model.EditPlan.Start.ToString("hh\\:mm")" />
                </div>

                <!-- KONEC -->
                <div class="col-md-3 mt-3">
                    <label>Konec</label>
                    <input name="End"
                           type="time"
                           class="form-control"
                           value="@Model.EditPlan.End.ToString("hh\\:mm")" />
                </div>

            </div>

            <button class="btn btn-success mt-3">Uložit</button>

            <button class="btn btn-secondary mt-3"
                    formmethod="post"
                    formaction="?handler=EditCancel">
                Zrušit
            </button>

        </form>
    </div>
}

@{
    var safeStart2 = Model.StartOfWeek == DateTime.MinValue
        ? DateTime.Today
        : Model.StartOfWeek;
}

<div class="container mt-4">
    <div class="schedule-grid">

        @for (int i = 0; i < 7; i++)
        {
            var date = safeStart2.AddDays(i);

            <div class="day-column border p-2 text-center @(date.DayOfWeek == DayOfWeek.Saturday ? "saturday" : date.DayOfWeek == DayOfWeek.Sunday ? "sunday" : "")">

                <strong>
                    @(
                        CultureInfo.GetCultureInfo("cs-CZ")
                            .TextInfo
                            .ToTitleCase(date.ToString("dddd", new CultureInfo("cs-CZ")))
                    )
                </strong><br />

                @date.ToString("dd.MM.")

                <hr />

                @foreach (var p in Model.Plans.Where(p => p.Date != default && p.Date.Date == date.Date))
                {
                    var taughtStyle = p.IsTaught
                        ? "opacity:0.7;border-left:4px solid #28a745;"
                        : "";

                    var bgColor = Model.GetColorForStudent(p.StudentId) ?? "#cccccc";

                    <div class="p-2 mb-2 rounded text-start"
                         style="background-color:@bgColor;@taughtStyle">

                        <strong>@p.Student.LastName @p.Student.FirstName</strong><br />
                        @p.Subject.Name – @p.SubjectTopic?.Name<br />
                        @p.Start.ToString(@"hh\:mm") – @p.End.ToString(@"hh\:mm")<br />

                        @if (!string.IsNullOrEmpty(p.MeetLink))
                        {
                            <a href="@p.MeetLink" target="_blank">Meet</a><br />
                        }

                        <div class="d-flex flex-row flex-nowrap gap-1 mt-1 align-items-center">

                            @if (!p.IsTaught)
                            {
                                <form method="post" asp-page-handler="Teach" class="m-0 p-0">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <input type="hidden" name="Week" value="@Model.Week.ToString("yyyy-MM-dd")" />

                                    <button class="btn btn-success btn-sm px-1 py-0"
                                            title="Označit jako odučené">
                                        ✔
                                    </button>
                                </form>
                            }

                            <form method="post"
                                  asp-page="/Admin/Schedule"
                                  asp-page-handler="EditStart"
                                  class="m-0 p-0">

                                <input type="hidden" name="id" value="@p.Id" />
                                <input type="hidden" name="Week" value="@Model.Week.ToString("yyyy-MM-dd")" />
                                <input type="hidden" name="TeacherId" value="@p.TeacherId" />

                                <button class="btn btn-warning btn-sm px-1 py-0"
                                        title="Upravit lekci">
                                    ✏
                                </button>
                            </form>



                            <form method="post" asp-page-handler="Delete" class="m-0 p-0">
                                <input type="hidden" name="id" value="@p.Id" />
                                <input type="hidden" name="Week" value="@Model.Week.ToString("yyyy-MM-dd")" />

                                <button class="btn btn-danger btn-sm px-1 py-0"
                                        title="Smazat lekci">
                                    🗑
                                </button>
                            </form>

                        </div>

                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const subjectSelect = document.getElementById("subjectSelect");
        const topicSelect = document.getElementById("topicSelect");

        if (subjectSelect && topicSelect) {
            subjectSelect.addEventListener("change", function () {
                const subjectId = this.value;

                fetch(`?handler=Topics&subjectId=${subjectId}`)
                    .then(response => response.json())
                    .then(data => {
                        topicSelect.innerHTML = '<option value="">-- Vyber téma --</option>';

                        data.forEach(t => {
                            const opt = document.createElement("option");
                            opt.value = t.id;
                            opt.textContent = t.name;
                            topicSelect.appendChild(opt);
                        });
                    })
                    .catch(err => console.error("Chyba při načítání témat:", err));
            });
        }
    </script>
}
