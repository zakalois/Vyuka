@page
@model LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Přihlášení";
}

<div class="container mt-5" style="max-width: 400px;">
    <h2 class="mb-4 text-center">Přihlášení</h2>

    <form method="post">
        <div class="mb-3">
            <label class="form-label">Uživatel</label>
            <select asp-for="Email" asp-items="Model.Users" class="form-select"></select>
        </div>

        <div class="mb-3">
            <label class="form-label">Heslo</label>
            <input type="password" asp-for="Password" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary w-100">Přihlásit</button>
    </form>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
    }
</div>
