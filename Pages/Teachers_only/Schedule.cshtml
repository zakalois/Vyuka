@page "/Teachers_only/Schedule"
@model Vyuka.Pages.Teachers_only.ScheduleModel

@{
    Layout = "_TeacherLayout";
}

<div class="container mt-4">

    <!-- Navigace týdnů -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a asp-page="/Teachers_only/Schedule" asp-route-week="@Model.PreviousWeek"
           class="btn btn-outline-primary">← Předchozí týden</a>

        <div class="text-center">
            <span class="fw-bold fs-5">@Model.WeekLabel</span><br />
            <a asp-page="/Teachers_only/Schedule" asp-route-week="0"
               class="btn btn-info mt-2"
               style="font-size: 1.2rem; padding: 10px 25px;">Aktuální týden</a>
        </div>

        <a asp-page="/Teachers_only/Schedule" asp-route-week="@Model.NextWeek"
           class="btn btn-outline-primary">Následující týden →</a>
    </div>


    <!-- 🟩 EDITACE -->
    @if (Model.EditingLesson != null)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white text-center">
                <strong>Upravit hodinu / plán</strong>
            </div>

            <div class="card-body">
                <form method="post" asp-page-handler="EditSave">

                    <input type="hidden" name="id" value="@Model.EditingLesson.Id" />
                    <input type="hidden" name="isPlan" value="@Model.EditingIsPlan" />

                    <div class="row g-2">
                        <div class="col-md-3">
                            <label class="form-label">Datum</label>
                            <input name="date" type="date"
                                   value="@Model.EditingLesson.Date.ToString("yyyy-MM-dd")"
                                   class="form-control" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Začátek</label>
                            <input name="start" type="time"
                                   value="@Model.EditingLesson.Start.ToString(@"hh\:mm")"
                                   class="form-control" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Konec</label>
                            <input name="end" type="time"
                                   value="@Model.EditingLesson.End.ToString(@"hh\:mm")"
                                   class="form-control" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Předmět</label>
                            <select name="subjectId" class="form-select">
                                @foreach (var s in Model.Subjects)
                                {
                                    <option value="@s.Id" selected="@(s.Id == Model.EditingLesson.SubjectId)">
                                        @s.Name
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4 mt-2">
                            <label class="form-label">Student</label>
                            <select name="studentId" class="form-select">
                                @foreach (var s in Model.Students)
                                {
                                    <option value="@s.Id" selected="@(s.Id == Model.EditingLesson.StudentId)">
                                        @s.LastName @s.FirstName
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="col-md-12 mt-2">
                            <label class="form-label">Meet link</label>
                            <input name="meetLink" class="form-control" value="@Model.EditingLesson.MeetLink" />
                        </div>

                    </div>

                    <button class="btn btn-success w-100 mt-3">Uložit změny</button>
                </form>
            </div>
        </div>
    }


    <!-- 🟨 PŘIDAT HODINU -->
    @if (Model.EditingLesson == null)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white text-center">
                <strong>Přidat hodinu</strong>
            </div>

            <div class="card-body">
                <form method="post" asp-page-handler="AddLesson">

                    <div class="row g-2">

                        <!-- STUDENT -->
                        <div class="col-md-3">
                            <label class="form-label">Student</label>
                            <select asp-for="NewLesson.StudentId" class="form-select">
                                @foreach (var s in Model.Students)
                                {
                                    <option value="@s.Id">@s.LastName @s.FirstName</option>
                                }
                            </select>
                        </div>

                        <!-- PŘEDMĚT -->
                        <div class="col-md-3">
                            <label class="form-label">Předmět</label>
                            <select asp-for="NewLesson.SubjectId" class="form-select">
                                @foreach (var subj in Model.Subjects)
                                {
                                    <option value="@subj.Id">@subj.Name</option>
                                }
                            </select>
                        </div>

                        <!-- DATUM -->
                        <div class="col-md-2">
                            <label class="form-label">Datum</label>
                            <input asp-for="NewLesson.Date" type="date" class="form-control" />
                        </div>

                        <!-- ZAČÁTEK -->
                        <div class="col-md-2">
                            <label class="form-label">Začátek</label>
                            <input asp-for="NewLesson.Start" type="time" class="form-control" />
                        </div>

                        <!-- KONEC -->
                        <div class="col-md-2">
                            <label class="form-label">Konec</label>
                            <input asp-for="NewLesson.End" type="time" class="form-control" />
                        </div>

                    </div>

                    <button type="submit" class="btn btn-success w-100 mt-3">
                        Přidat hodinu
                    </button>

                </form>
            </div>
        </div>
    }


    <!-- 🟦 TÝDENNÍ ROZVRH -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-center">
            <strong>Týdenní rozvrh</strong>
        </div>

        <div class="card-body">
            <div class="schedule-grid">

                @foreach (var day in Model.WeeklySchedule)
                {
                    string dayClass = day.Day switch
                    {
                        "Sobota" => "day-sat",
                        "Neděle" => "day-sun",
                        _ => ""
                    };

                    <div class="day-column @dayClass">
                        <div class="day-header">
                            <strong>@day.Day</strong><br />
                            <small class="text-muted">@day.Date.ToString("dd.MM.")</small><br />
                            <span class="text-muted">@day.Lessons.Sum(l => (l.End - l.Start).TotalHours) hodin</span>
                        </div>

                        <hr />

                        @if (day.Lessons.Any())
                        {
                            foreach (var l in day.Lessons)
                            {
                                <div class="lesson-block @(l.IsTaught ? "taught" : "")" style="background-color:@l.Color">

                                    <div class="lesson-body">
                                        <strong>@l.Student</strong><br />
                                        <span class="text-muted">@l.Subject</span><br />
                                        @l.Start.ToString(@"hh\:mm") – @l.End.ToString(@"hh\:mm")<br />

                                        @if (!string.IsNullOrEmpty(l.MeetLink))
                                        {
                                            <a href="@l.MeetLink" target="_blank" class="meet-link">Meet</a>
                                        }

                                        <div class="lesson-icons mt-1">

                                            @if (l.LessonId != null || l.LessonPlanId != null)
                                            {
                                                <form method="post" asp-page-handler="EditStart" class="m-0 p-0 d-inline">
                                                    <input type="hidden" name="id" value="@(l.LessonId ?? l.LessonPlanId)" />
                                                    <input type="hidden" name="Week" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                                                    <button class="icon-btn">✏️</button>
                                                </form>
                                            }

                                            @if (l.LessonId != null || l.LessonPlanId != null)
                                            {
                                                <form method="post" asp-page-handler="DeleteLesson" class="m-0 p-0 d-inline">
                                                    <input type="hidden" name="id" value="@(l.LessonId ?? l.LessonPlanId)" />
                                                    <input type="hidden" name="Week" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                                                    <button class="icon-btn">🗑️</button>
                                                </form>
                                            }

                                            @if ((l.LessonId != null || l.LessonPlanId != null) && !l.IsTaught)
                                            {
                                                <form method="post" asp-page-handler="TeachLesson" class="m-0 p-0 d-inline">
                                                    <input type="hidden" name="id" value="@(l.LessonId ?? l.LessonPlanId)" />
                                                    <input type="hidden" name="Week" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                                                    <button class="icon-btn">✔️</button>
                                                </form>
                                            }

                                        </div>

                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-muted small">Žádné hodiny</div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
