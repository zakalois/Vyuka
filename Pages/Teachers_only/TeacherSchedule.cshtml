@page
@model Vyuka.Pages.Teachers_only.TeacherScheduleModel

@{
    Layout = "_TeacherLayout";
}

<div class="container mt-4">

    <!-- Navigace týdnů -->
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
        <a class="btn btn-secondary" asp-page="./TeacherSchedule" asp-route-week="@Model.PreviousWeek">
            ← Předchozí týden
        </a>

        <div class="text-center mx-2">
            <h5 class="mb-1">
                @Model.StartOfWeek.ToString("dd.MM.yyyy")
                –
                @Model.EndOfWeek.ToString("dd.MM.yyyy")
            </h5>
            <a class="btn btn-info btn-sm" asp-page="./TeacherSchedule" asp-route-week="0">
                Aktuální týden
            </a>
        </div>

        <a class="btn btn-secondary" asp-page="./TeacherSchedule" asp-route-week="@Model.NextWeek">
            Další týden →
        </a>
    </div>

    <!-- 🟨 PŘIDAT / EDITOVAT HODINU -->
    @if (Model.EditingLesson == null)
    {
        <!-- FORMULÁŘ PRO PŘIDÁNÍ -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white text-center">
                <strong>Přidat hodinu</strong>
            </div>

            <div class="card-body">

                <form method="post" asp-page-handler="AddLesson">
                    <input type="hidden" name="week" value="@Model.Week" />

                    <div class="row">

                        <div class="col-md-3">
                            <label class="form-label">Student</label>
                            <select name="NewLesson.StudentId" class="form-select" id="addStudentSelect">
                                @foreach (var s in Model.Students)
                                {
                                    <option value="@s.Id">@s.LastName @s.FirstName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Předmět</label>
                            <select name="NewLesson.SubjectId" class="form-select" id="addSubjectSelect">
                                @foreach (var s in Model.Subjects)
                                {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Téma</label>
                            <select name="NewLesson.SubjectTopicId" class="form-select" id="addTopicSelect">
                                <option value="">-- Vyber téma --</option>
                                @foreach (var t in Model.Topics)
                                {
                                    <option value="@t.Id" data-subject="@t.SubjectId">@t.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Datum</label>
                            <input name="NewLesson.Date" type="date" class="form-control" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Začátek</label>
                            <input name="NewLesson.Start" type="time" class="form-control" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Konec</label>
                            <input name="NewLesson.End" type="time" class="form-control" />
                        </div>

                    </div>

                    <button type="submit" class="btn btn-success w-100 mt-3">
                        Přidat hodinu
                    </button>
                </form>

            </div>
        </div>
    }
    else
    {
        <!-- FORMULÁŘ PRO EDITACI -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white text-center">
        <strong>Upravit hodinu</strong>
    </div>

    <div class="card-body">

        <form method="post" asp-page-handler="EditSave">

            <!-- Skryté hodnoty -->
                    <input type="hidden" name="id" value="@Model.EditingLesson.LessonPlanId" />
                    <input type="hidden" name="week" value="@Model.Week" />


            <div class="row">

                <!-- STUDENT -->
                <div class="col-md-3">
                    <label class="form-label">Student</label>
                            <select name="studentId" class="form-select" id="editStudentSelect">
                                @foreach (var s in Model.Students)
                                {
                                    <option value="@s.Id" selected="@(s.Id == Model.EditingLesson.StudentId)">
                                        @s.LastName @s.FirstName
                                    </option>
                                }
                            </select>

                </div>

                <!-- PŘEDMĚT -->
                <div class="col-md-3">
                    <label class="form-label">Předmět</label>
                            <select name="subjectId" class="form-select" id="editSubjectSelect">
                                @foreach (var s in Model.Subjects)
                                {
                                    <option value="@s.Id" selected="@(s.Id == Model.EditingLesson.SubjectId)">
                                        @s.Name
                                    </option>
                                }
                            </select>

                </div>

                <!-- TÉMA -->
                <div class="col-md-3">
                    <label class="form-label">Téma</label>
                            <select name="subjectTopicId" class="form-select" id="editTopicSelect">
                                <option value="">-- Vyber téma --</option>
                                @foreach (var t in Model.Topics)
                                {
                                    <option value="@t.Id"
                                            data-subject="@t.SubjectId"
                                            selected="@(t.Id == Model.EditingLesson.SubjectTopicId)">
                                        @t.Name
                                    </option>
                                }
                            </select>

                </div>

                <!-- DATUM -->
                <div class="col-md-2">
                    <label class="form-label">Datum</label>
                    <input name="date" type="date" class="form-control"
                           value="@Model.EditingLesson.Date.ToString("yyyy-MM-dd")" />
                </div>

                <!-- ZAČÁTEK -->
                <div class="col-md-2">
                    <label class="form-label">Začátek</label>
                    <input name="start" type="time" class="form-control"
                           value="@Model.EditingLesson.Start.ToString(@"hh\:mm")" />
                </div>

                <!-- KONEC -->
                <div class="col-md-2">
                    <label class="form-label">Konec</label>
                    <input name="end" type="time" class="form-control"
                           value="@Model.EditingLesson.End.ToString(@"hh\:mm")" />
                </div>

            </div>

            <button type="submit" class="btn btn-primary w-100 mt-3">
                Uložit změny
            </button>

            <a class="btn btn-secondary w-100 mt-2"
               asp-page="./TeacherSchedule"
               asp-route-week="@Model.Week">
                Zrušit
            </a>

        </form>

    </div>
</div>

    }

    <!-- 🟦 TÝDENNÍ ROZVRH -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-center">
            <strong>Týdenní rozvrh</strong>
        </div>

        <div class="card-body">
            <div class="schedule-grid">

                @foreach (var day in Model.WeeklySchedule)
                {
                    string dayClass = day.Day switch
                    {
                        "Sobota" => "day-sat",
                        "Neděle" => "day-sun",
                        _ => ""
                    };

                    <div class="day-column @dayClass">
                        <div class="day-header">
                            <strong>@day.Day</strong><br />
                            <small class="text-muted">@day.Date.ToString("dd.MM.")</small><br />
                            <span class="text-muted">
                                @day.Lessons.Sum(l => (l.End - l.Start).TotalHours) hodin
                            </span>
                        </div>

                        <hr />

                        @if (day.Lessons.Any())
                        {
                            foreach (var l in day.Lessons)
                            {
                                <div class="lesson-block @(l.IsTaught ? "taught" : "")"
                                     style="background-color:@l.Color">

                                    <div class="lesson-body">
                                        <strong>@l.Student</strong><br />

                                        @if (!string.IsNullOrEmpty(l.SubjectTopic))
                                        {
                                            <span class="text-muted">@l.SubjectTopic</span><br />
                                        }

                                        <span class="text-muted">@l.Subject</span><br />
                                        @l.Start.ToString(@"hh\:mm") – @l.End.ToString(@"hh\:mm")<br />

                                        @if (!string.IsNullOrEmpty(l.MeetLink))
                                        {
                                            <a href="@l.MeetLink" target="_blank" class="meet-link">Meet</a>
                                        }

                                        <div class="lesson-icons mt-1">

                                            <!-- EDITACE -->
                                            <form method="get" class="d-inline">

                                                @if (l.LessonPlanId != null)
                                                {
                                                    <!-- Plánovaná hodina -->
                                                    <input type="hidden" name="editId" value="@l.LessonPlanId" />
                                                }
                                                else
                                                {
                                                    <!-- Odučená hodina – NEEDITUJEME -->
                                                    <input type="hidden" name="editId" value="" />
                                                }

                                                <input type="hidden" name="week" value="@Model.Week" />
                                                <button class="icon-btn" type="submit" @(l.LessonPlanId == null ? "disabled" : "")>✏️</button>
                                            </form>





                                            <!-- SMAZÁNÍ -->
                                            <form method="post"
                                                  asp-page-handler="@(l.LessonId != null ? "DeleteLesson" : "DeletePlan")"
                                                  class="d-inline">
                                                <input type="hidden" name="id" value="@(l.LessonId ?? l.LessonPlanId)" />
                                                <input type="hidden" name="week" value="@Model.Week" />
                                                <button class="icon-btn" type="submit">🗑️</button>
                                            </form>

                                            <!-- OZNAČIT JAKO ODUČENÉ -->
                                            @if (!l.IsTaught)
                                            {
                                                <form method="post" asp-page-handler="TeachLesson" class="d-inline">
                                                    <input type="hidden" name="id" value="@(l.LessonId ?? l.LessonPlanId)" />
                                                    <input type="hidden" name="week" value="@Model.Week" />
                                                    <button class="icon-btn" type="submit">✔️</button>
                                                </form>
                                            }

                                        </div>

                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-muted small">Žádné hodiny</div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    function filterTopics(subjectId, topicId) {
        const subjectSelect = document.getElementById(subjectId);
        const topicSelect = document.getElementById(topicId);
        if (!subjectSelect || !topicSelect) return;

        const selectedSubject = subjectSelect.value;

        topicSelect.querySelectorAll("option[data-subject]").forEach(opt => {
            opt.style.display = opt.getAttribute("data-subject") === selectedSubject ? "" : "none";
        });

        if (topicSelect.selectedOptions.length > 0) {
            const sel = topicSelect.selectedOptions[0];
            if (sel.getAttribute("data-subject") !== selectedSubject) {
                topicSelect.value = "";
            }
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        filterTopics("addSubjectSelect", "addTopicSelect");
        filterTopics("editSubjectSelect", "editTopicSelect");

        document.getElementById("addSubjectSelect")?.addEventListener("change", () => filterTopics("addSubjectSelect", "addTopicSelect"));
        document.getElementById("editSubjectSelect")?.addEventListener("change", () => filterTopics("editSubjectSelect", "editTopicSelect"));

        @if (Model.EditingLesson != null)
        {
                <text>
                        document.getElementById("editStudentSelect").value = "@Model.EditingLesson.StudentId";
                        document.getElementById("editSubjectSelect").value = "@Model.EditingLesson.SubjectId";
                        document.getElementById("editTopicSelect").value = "@Model.EditingLesson.SubjectTopicId";
                </text>
        }
    });
</script>
