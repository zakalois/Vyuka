@page "/Admin/Students/Edit/{id:int}"
@model Vyuka.Pages.Admin.Students.EditModel

<h1>Upravit studenta</h1>

<form method="post">
    <input type="hidden" asp-for="Student.Id" />

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="row">

        <div class="col-md-6 mb-3">
            <label>Jméno</label>
            <input asp-for="Student.FirstName" class="form-control" />
            <span asp-validation-for="Student.FirstName" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Příjmení</label>
            <input asp-for="Student.LastName" class="form-control" />
            <span asp-validation-for="Student.LastName" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label>Věk</label>
            <input asp-for="Student.Age" class="form-control" />
            <span asp-validation-for="Student.Age" class="text-danger"></span>
        </div>

        <div class="col-md-8 mb-3">
            <label>Email</label>
            <input asp-for="Student.Email" class="form-control" />
            <span asp-validation-for="Student.Email" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Telefon</label>
            <input asp-for="Student.Phone" class="form-control" />
            <span asp-validation-for="Student.Phone" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Škola</label>
            <input asp-for="Student.School" class="form-control" />
            <span asp-validation-for="Student.School" class="text-danger"></span>
        </div>

        <div class="col-md-12 mb-3">
            <label>Adresa</label>
            <input asp-for="Student.Address" class="form-control" />
            <span asp-validation-for="Student.Address" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Předmět</label>
            <select asp-for="Student.SubjectId" asp-items="Model.Subjects" class="form-select"></select>
            <span asp-validation-for="Student.SubjectId" class="text-danger"></span>
        </div>

        <h4 class="mt-4">Rodič</h4>

        <div class="col-md-6 mb-3">
            <label>Jméno rodiče</label>
            <input asp-for="Student.ParentFirstName" class="form-control" />
            <span asp-validation-for="Student.ParentFirstName" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Příjmení rodiče</label>
            <input asp-for="Student.ParentLastName" class="form-control" />
            <span asp-validation-for="Student.ParentLastName" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Email rodiče</label>
            <input asp-for="Student.ParentEmail" class="form-control" />
            <span asp-validation-for="Student.ParentEmail" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Telefon rodiče</label>
            <input asp-for="Student.ParentPhone" class="form-control" />
            <span asp-validation-for="Student.ParentPhone" class="text-danger"></span>
        </div>

        <div class="col-md-12 mb-3">
            <label>Poznámka rodiče</label>
            <textarea asp-for="Student.Note" class="form-control"></textarea>
            <span asp-validation-for="Student.Note" class="text-danger"></span>
        </div>

    </div>

    <button type="submit" class="btn btn-primary">
        <i class="bi bi-save"></i> Uložit změny
    </button>

    <a asp-page="/Admin/Students/Overview" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Zpět
    </a>

</form>
