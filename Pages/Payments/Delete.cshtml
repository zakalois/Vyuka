@page "{id:int}"
@model Vyuka.Pages.Payments.DeleteModel

<h2>Smazat platbu</h2>

<div class="alert alert-danger">
    <strong>Opravdu chceš smazat tuto platbu?</strong>
    <br /><br />
    <strong>Datum:</strong> @Model.Payment.Date.ToShortDateString() <br />
    <strong>Částka:</strong> @Model.Payment.Amount Kč <br />
    <strong>Předplacené hodiny:</strong> @Model.Payment.HoursPurchased h <br />
    <strong>Způsob:</strong> @Model.Payment.Method <br />
    <strong>Poznámka:</strong> @Model.Payment.Note
</div>

<form method="post">
    <button type="submit" class="btn btn-danger">Smazat</button>
    <a asp-page="/Payments/Index" class="btn btn-secondary">Zpět</a>
</form>