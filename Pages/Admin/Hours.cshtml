@page "/Admin/Hours"
@model Vyuka.Pages.Admin.HoursModel

<h1>Přehled hodin</h1>

<!-- HORNÍ PŘEHLED -->
<div class="row mb-4">

    <div class="col-md-4">
        <div class="alert alert-warning text-center">
            <strong>Předplacené:</strong><br />
            @Model.TotalPrepaidHours.ToString("0.0") h
        </div>
    </div>

    <div class="col-md-4">
        <div class="alert alert-success text-center">
            <strong>Odučené:</strong><br />
            @Model.TotalTaughtHours.ToString("0.0") h
        </div>
    </div>

    <div class="col-md-4">
        <div class="alert alert-danger text-center">
            <strong>Zbývá odučit:</strong><br />
            @Model.TotalRemainingHours.ToString("0.0") h
        </div>
    </div>

</div>

<!-- FILTR -->
<form method="get" class="mb-4">
    <div class="row g-3 align-items-end">

        <div class="col-md-4">
            <label class="form-label">Vyber studenta:</label>
            <select name="studentId" class="form-select" onchange="this.form.submit()">
                <option value="">Vyber studenta</option>
                @foreach (var s in Model.Students)
                {
                    <option value="@s.Id" selected="@(Model.SelectedStudentId == s.Id)">
                        @s.LastName @s.FirstName
                    </option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Od:</label>
            <input type="date" name="from" class="form-control"
                   value="@(Model.From.HasValue && Model.From.Value != DateTime.MinValue
                                              ? Model.From.Value.ToString("yyyy-MM-dd")
                                              : "")" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Do:</label>
            <input type="date" name="to" class="form-control"
                   value="@(Model.To.HasValue && Model.To.Value != DateTime.MinValue
                                              ? Model.To.Value.ToString("yyyy-MM-dd")
                                              : "")" />
        </div>


        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filtrovat</button>
        </div>

    </div>
</form>

@if (Model.SelectedStudent != null)
{
    <h3>@Model.SelectedStudent.LastName @Model.SelectedStudent.FirstName</h3>

    <!-- SOUHRN STUDENTA -->
    <div class="row mb-4">

        <div class="col-md-3">
            <div class="alert alert-info text-center">
                <strong>Zaplacené:</strong><br />
                @Model.PaidHours.ToString("0.0") h
            </div>
        </div>

        <div class="col-md-3">
            <div class="alert alert-warning text-center">
                <strong>Plánované v intervalu:</strong><br />
                @Model.PlannedHours.ToString("0.0") h
            </div>
        </div>

        <div class="col-md-3">
            <div class="alert alert-success text-center">
                <strong>Odučené v intervalu:</strong><br />
                @Model.TaughtHours.ToString("0.0") h
            </div>
        </div>

        <div class="col-md-3">
            <div class="alert alert-danger text-center">
                <strong>Zbývá (celkem):</strong><br />
                @Model.RemainingHours.ToString("0.0") h
            </div>
        </div>

    </div>

    <!-- DALŠÍ PLÁNOVANÁ HODINA -->
    @if (Model.NextLesson != null)
    {
        <div class="alert alert-info text-center" style="border: 3px solid black;">
            <strong>Další plánovaná hodina:</strong><br />
            @Model.NextLesson.Date.ToString("dd.MM.yyyy")
            @Model.NextLesson.Start.ToString(@"hh\:mm")
            –
            @Model.NextLesson.End.ToString(@"hh\:mm")
            (@((Model.NextLesson.End - Model.NextLesson.Start).TotalHours.ToString("0.0")) h)
        </div>
    }

    <!-- TABULKA -->
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>Datum</th>
                <th>Od</th>
                <th>Do</th>
                <th>Hodin</th>
                <th>Typ</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var l in Model.UnifiedLessons)
            {
                var css = l.IsTaught ? "table-success" : "table-warning";

                <tr class="@css">
                    <td>@l.Date.ToString("dd.MM.yyyy")</td>
                    <td>@l.Start.ToString(@"hh\:mm")</td>
                    <td>@l.End.ToString(@"hh\:mm")</td>
                    <td>@((l.End - l.Start).TotalHours.ToString("0.0"))</td>
                    <td>@(l.IsTaught ? "Odučeno" : "Plánováno")</td>
                </tr>
            }
        </tbody>
    </table>
}
