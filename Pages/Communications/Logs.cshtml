@page
@model Vyuka.Pages.Communications.LogsModel

<h2>Log odeslaných e‑mailů</h2>

<form method="get" class="row g-3 mt-3 mb-4">

    <div class="col-md-3">
        <label class="form-label">Typ e‑mailu</label>
        <select name="Type" class="form-select">
            <option value="">Vše</option>

            @foreach (var item in new[] {
        new { Value = "payment", Text = "Platba" },
        new { Value = "birthday", Text = "Narozeniny" },
        new { Value = "offer", Text = "Nabídka" },
        new { Value = "system", Text = "Systém" }
    })
            {
                if (Model.Type == item.Value)
                {
                    <option value="@item.Value" selected>@item.Text</option>
                }
                else
                {
                    <option value="@item.Value">@item.Text</option>
                }
            }
        </select>

    </div>

    <div class="col-md-3">
        <label class="form-label">Student</label>
        <select name="StudentId" class="form-select">
            <option value="">Všichni</option>
            @foreach (var s in Model.Students)
            {
                <option value="@s.Id" selected="@(Model.StudentId == s.Id)">
                    @s.LastName @s.FirstName
                </option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label">Od</label>
        <input type="date" name="From" value="@Model.From?.ToString("yyyy-MM-dd")" class="form-control" />
    </div>

    <div class="col-md-2">
        <label class="form-label">Do</label>
        <input type="date" name="To" value="@Model.To?.ToString("yyyy-MM-dd")" class="form-control" />
    </div>

    <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-primary w-100">Filtrovat</button>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Datum</th>
            <th>Komu</th>
            <th>Předmět</th>
            <th>Typ</th>
            <th>QR</th>
            <th>Stav</th>
            <th>Detail</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var log in Model.Logs)
        {
            <tr>
                <td>@log.SentAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@log.Recipient</td>
                <td>@log.Subject</td>
                <td>@log.EmailType</td>

                <td>
                    @if (log.HasQrCode)
                    {
                        <span style="color: green; font-weight: bold;">✔</span>
                    }
                    else
                    {
                        <span style="color: gray;">–</span>
                    }
                </td>

                <td>
                    @if (log.Success)
                    {
                        <span class="badge bg-success">OK</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Chyba</span>
                    }
                </td>

                <td>
                    <a asp-page="/Communications/LogsDetail" asp-route-id="@log.Id" class="btn btn-sm btn-primary">
                        Detail
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<form method="get" asp-page-handler="Clean" class="mt-3">
    <button class="btn btn-danger">Vyčistit staré logy</button>
</form>
