<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Výuka</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- Vlastní styly -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Skripty -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>
    <!-- ========================================= -->
    <!-- ADMIN HEADER -->
    <!-- ========================================= -->
@*     <header class="admin-header">
        <div class="admin-left">
            Administrace
        </div>

        <div class="admin-right">
            <button id="darkToggle" class="btn btn-sm btn-primary">
                Tmavý režim
            </button>

            <form method="post" asp-page="/Logout">
                <button type="submit" class="btn btn-sm btn-danger">
                    Odhlásit se
                </button>
            </form>
        </div>
    </header>
 *@

    <!-- ========================================= -->
    <!-- ADMIN MENU -->
    <!-- ========================================= -->
    <nav class="admin-menu d-flex gap-3 px-4 py-2">

        <a class="nav-link" href="/Admin/Dashboard">Dashboard</a>
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="studentsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-people-fill me-1"></i> Studenti
            </a>

            <ul class="dropdown-menu" aria-labelledby="studentsDropdown">

                <li>
                    <a class="dropdown-item" asp-page="/Admin/Students/Overview">
                        <i class="bi bi-table me-2"></i> Přehled studentů
                    </a>
                </li>

                <li>
                    <a class="dropdown-item" asp-page="/Admin/Students/Index">
                        <i class="bi bi-person-lines-fill me-2"></i> Přiřazení učitelů
                    </a>
                </li>

                <li>
                    <a class="dropdown-item" asp-page="/Admin/Students/Create">
                        <i class="bi bi-person-plus-fill me-2"></i> Přidat studenta
                    </a>
                </li>

            </ul>
        </li>

        <a class="nav-link" asp-page="/Admin/Teachers/Teachers">Učitelé</a>
        <a class="nav-link" href="/Admin/Hours">Odučené hodiny</a>

        <!-- ⭐ OPRAVENO: přidána class="nav-link" + správná route -->
        <a class="nav-link" asp-page="/Admin/Schedule/Index">Rozvrh</a>
        <a class="nav-link" href="/Payments/Index">Finance</a>
        <a class="nav-link" href="/Communications">E‑maily</a>

        <a class="nav-link" href="/Account/Profile">
            <i class="bi bi-person-circle"></i> Profil
        </a>
        <div class="admin-right">
            <button id="darkToggle" class="btn btn-sm btn-light">
                Tmavý režim
            </button>
        </div>


    </nav>



    <!-- ========================================= -->
    <!-- OBSAH STRÁNKY -->
    <!-- ========================================= -->
    <main role="main" class="container mt-4">
        @RenderBody()
    </main>

    <!-- ========================================= -->
    <!-- DARK MODE SCRIPT -->
    <!-- ========================================= -->
    <script>
            (function () {
                const body = document.body;
                const toggle = document.getElementById('darkToggle');

                const saved = localStorage.getItem('theme');
                if (saved === 'dark') {
                    body.classList.add('dark');
                    toggle.textContent = 'Světlý režim';
                }

                toggle.addEventListener('click', function () {
                    body.classList.toggle('dark');
                    const isDark = body.classList.contains('dark');
                    toggle.textContent = isDark ? 'Světlý režim' : 'Tmavý režim';
                    localStorage.setItem('theme', isDark ? 'dark' : 'light');
                });
            })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
