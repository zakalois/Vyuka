@using Microsoft.AspNetCore.Identity
@inject UserManager<Vyuka.Models.AppUser> UserManager
@{
    var teacher = await UserManager.GetUserAsync(User);
}

@inherits Microsoft.AspNetCore.Mvc.Razor.RazorPage<dynamic>
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@teacher.LastName @teacher.FirstName – Výuka</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body class="dark">
    @{
        var env = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT");
    }

    @if (env == "Development")
    {
        <div style="background:#b30000; color:white; padding:6px 12px; text-align:center; font-weight:bold;">
            ⚠️ DEVELOPMENT – TESTOVACÍ PROSTŘEDÍ
        </div>
    }
    else
    {
        <div style="background:#28a745; color:white; padding:6px 12px; text-align:center; font-weight:bold;">
            ✔️ PRODUCTION – OSTRÉ PROSTŘEDÍ
        </div>
    }


    <!-- HORNÍ NAVIGACE -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary px-4 py-2 shadow">

        <div class="container-fluid">

            <!-- Jméno učitele -->
            <a class="navbar-brand fw-bold d-flex align-items-center" asp-page="/Teachers_only/Dashboard">
                <i class="bi bi-person-circle me-2" style="color:#ffe066; font-size:1.4rem;"></i>
                @teacher.LastName @teacher.FirstName
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#teacherNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="teacherNav">

                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <!-- STUDENTI DROPDOWN -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-people-fill me-2" style="color:#ffd966;"></i>
                            Studenti
                        </a>

                        <ul class="dropdown-menu">

                            <li>
                                <a class="dropdown-item d-flex align-items-center" asp-page="/Teachers_only/Students/Index">
                                    <i class="bi bi-list-ul me-2"></i>
                                    Moji studenti
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item d-flex align-items-center" asp-page="/Teachers_only/TeacherHours">
                                    <i class="bi bi-journal-check me-2"></i>
                                    Odučené hodiny
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item d-flex align-items-center" asp-page="/Teachers_only/TeacherSchedule">
                                    <i class="bi bi-plus-circle me-2"></i>
                                    Přidat hodinu
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item d-flex align-items-center" asp-page="/Teachers_only/Students/Create">
                                    <i class="bi bi-person-plus-fill me-2"></i>
                                    Přidat studenta
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item d-flex align-items-center" asp-page="/Teachers_only/Notes/Index">
                                    <i class="bi bi-journal-text me-2" style="color:#ffdf80;"></i>
                                    Poznámky
                                </a>
                            </li>


                        </ul>
                    </li>



                    <!-- TÝDENNÍ ROZVRH -->
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center" asp-page="/Teachers_only/TeacherSchedule">
                            <i class="bi bi-calendar-week me-2" style="color:#d5b3ff;"></i>
                            Týdenní rozvrh
                        </a>
                    </li>

                    <!-- POZNÁMKY -->
                    @* <li class="nav-item">
                        <a class="nav-link d-flex align-items-center" asp-page="/Teachers_only/Notes/Index">
                            <i class="bi bi-journal-text me-2" style="color:#ffdf80;"></i>
                            Poznámky
                        </a>
                    </li> *@

                </ul>


                <div class="d-flex align-items-center">

                    <!-- Přepínač režimu -->
                    <button id="themeToggle" class="btn btn-outline-light me-3">
                        <i class="bi bi-brightness-high"></i> / <i class="bi bi-moon"></i>
                    </button>

                    <!-- Odhlášení -->
                    <form method="post" asp-page="/Logout">
                        <button type="submit" class="btn btn-danger d-flex align-items-center">
                            <i class="bi bi-box-arrow-right me-2"></i> Odhlásit
                        </button>
                    </form>

                </div>

            </div>

        </div>

    </nav>

    <!-- OBSAH STRÁNKY -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Přepínání režimu -->
    <script>
        (function () {
        const body = document.body;
        const toggle = document.getElementById('themeToggle');

        const saved = localStorage.getItem('theme');

        if (saved === 'light') {
        body.classList.add('light');
        } else {
        body.classList.add('dark');
        }

        toggle.addEventListener('click', function () {
        if (body.classList.contains('dark')) {
        body.classList.remove('dark');
        body.classList.add('light');
        localStorage.setItem('theme', 'light');
        } else {
        body.classList.remove('light');
        body.classList.add('dark');
        localStorage.setItem('theme', 'dark');
        }
        });
        })();
    </script>

</body>
</html>
