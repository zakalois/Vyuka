@page
@model Vyuka.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Můj profil";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="mb-4">Můj profil</h2>

    <div class="card p-3">

        <div class="text-center mb-3">
            <img src="@(Model.CurrentUser.PhotoPath ?? "/images/profile-placeholder.png")"
                 style="width:140px;height:140px;border-radius:50%;object-fit:cover;border:3px solid #ddd;" />
        </div>

        <p><strong>Jméno:</strong> @Model.CurrentUser.FirstName @Model.CurrentUser.LastName</p>
        <p><strong>Email:</strong> @Model.CurrentUser.Email</p>
        <p><strong>Telefon:</strong> @Model.CurrentUser.PhoneNumber</p>
        <p><strong>Role:</strong> @Model.CurrentUser.Role</p>

    </div>

    <div class="mt-4 d-flex gap-2">
        <a asp-page="/Account/EditProfile" class="btn btn-primary">Upravit profil</a>
        <a asp-page="/Account/ChangePassword" class="btn btn-warning">Změnit heslo</a>
        <a asp-page="/Index" class="btn btn-secondary">Zpět</a>
    </div>
</div>
