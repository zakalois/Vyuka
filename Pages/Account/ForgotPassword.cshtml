@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Zapomenuté heslo";
}

<div class="container mt-4" style="max-width: 500px;">
    <h2>Zapomenuté heslo</h2>

    <form method="post">
        <div class="mb-3">
            <label class="form-label">Vyberte uživatele</label>
            <select asp-for="Email" asp-items="Model.Users" class="form-select"></select>
        </div>

        <button type="submit" class="btn btn-warning w-100">Odeslat nové heslo</button>
    </form>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-info mt-3">@Model.Message</div>
    }
</div>
