@page "{id:int}"
@model Vyuka.Pages.Admin.Teachers.TeacherDetailModel

<h2>Detail učitele</h2>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <h4>@Model.Teacher.User.FirstName @Model.Teacher.User.LastName</h4>

        <p><strong>Email:</strong> <a href="mailto:@Model.Teacher.User.Email">@Model.Teacher.User.Email</a></p>
        <p><strong>Telefon:</strong> @Model.Teacher.User.PhoneNumber</p>
        <p><strong>Role:</strong> @Model.Teacher.User.Role</p>

        @if (!string.IsNullOrEmpty(Model.Teacher.User.PhotoPath))
        {
            <p><strong>Foto:</strong></p>
            <img src="@Model.Teacher.User.PhotoPath" style="max-width: 200px;" />
        }

        <a asp-page="/Admin/Teachers/Teachers" class="btn btn-secondary mt-3">Zpět</a>
    </div>
</div>
