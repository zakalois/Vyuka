@page
@model Vyuka.Pages.Communications.SendTeachingOfferModel
@{
    ViewData["Title"] = "Nabídka výuky";
}

<h2 class="mb-4">Nabídka výuky</h2>

<!-- 🔥 Zobrazení hlášek -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form method="post" enctype="multipart/form-data" class="mt-3">

    <!-- ⭐ Výběr studenta -->
    <div class="mb-3">
        <label class="form-label">Student</label>
        <select asp-for="SelectedStudentId" asp-items="Model.StudentList" class="form-select"></select>
    </div>

    <!-- ⭐ Předmět -->
    <div class="mb-3">
        <label class="form-label">Předmět e‑mailu</label>
        <input asp-for="Subject" class="form-control" value="Nabídka výuky" />
    </div>

    <!-- ⭐ Cena -->
    <div class="mb-3">
        <label class="form-label">Cena (Kč)</label>
        <input asp-for="Amount" class="form-control" placeholder="např. 300" />
    </div>

    <!-- ⭐ Zpráva pro příjemce -->
    <div class="mb-3">
        <label class="form-label">Zpráva pro příjemce (QR kód)</label>
        <input asp-for="PaymentMessage" class="form-control" placeholder="např. Výuka – Žák Karel" />
    </div>

    <!-- ⭐ Vlastní text -->
    <div class="mb-3">
        <label class="form-label">Vlastní text</label>
        <textarea asp-for="Message" class="form-control" rows="6" placeholder="Doplňující informace…"></textarea>
    </div>

    <!-- ⭐ Přílohy -->
    <div class="mb-3">
        <label class="form-label">Přílohy</label>
        <input asp-for="Attachments" type="file" class="form-control" multiple />
    </div>

    <button type="submit" class="btn btn-primary">Odeslat nabídku</button>
</form>

<!-- ⭐ Náhled e‑mailu -->
@if (Model.PreviewHtml != null)
{
    <hr class="my-4" />
    <h4>Náhled e‑mailu</h4>
    <div class="border p-3 bg-white">
        @Html.Raw(Model.PreviewHtml)
    </div>
}
