@page
@using System.Globalization
@model Vyuka.Pages.Schedule.ScheduleIndexModel

@{
    var safeStart = Model.StartOfWeek == DateTime.MinValue
        ? DateTime.Today
        : Model.StartOfWeek;

    var safeEnd = Model.EndOfWeek == DateTime.MinValue
        ? safeStart.AddDays(6)
        : Model.EndOfWeek;
}

<h1>Týdenní rozvrh</h1>

<div class="d-flex justify-content-between align-items-center mb-4">

    <a class="btn btn-secondary"
       asp-page="./Index"
       asp-route-week="@safeStart.AddDays(-7).ToString("yyyy-MM-dd")">
        ← Předchozí týden
    </a>

    <div class="text-center">
        <h4>@safeStart.ToString("dd.MM.yyyy") – @safeEnd.ToString("dd.MM.yyyy")</h4>

        <a class="btn btn-info mt-2"
           asp-page="./Index"
           asp-route-week="@DateTime.Today.ToString("yyyy-MM-dd")">
            Aktuální týden
        </a>
    </div>

    <a class="btn btn-secondary"
       asp-page="./Index"
       asp-route-week="@safeStart.AddDays(7).ToString("yyyy-MM-dd")">
        Další týden →
    </a>

</div>

@if (Model.EditPlan == null)
{
    <div class="card p-3 mb-4 shadow-sm">
        <h5>Přidat hodinu</h5>

        <form method="post" asp-page-handler="Add">

            <input type="hidden" name="Week" value="@Model.Week.ToString("yyyy-MM-dd")" />

            <div class="row">

                <!-- STUDENT -->
                <div class="col-md-3">
                    <label>Student</label>
                    <select name="NewStudentId" class="form-control">
                        @foreach (var s in Model.Students)
                        {
                            <option value="@s.Id">@s.LastName @s.FirstName</option>
                        }
                    </select>
                </div>

                <!-- PŘEDMĚT -->
                <div class="col-md-3">
                    <label>Předmět</label>
                    <select name="NewSubjectId" class="form-select" id="subjectSelect">
                        <option value="">-- Vyber předmět --</option>
                        @foreach (var s in Model.Subjects)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>

                <!-- TÉMA -->
                <div class="col-md-3">
                    <label>Téma</label>
                    <select name="NewTopicId" class="form-select" id="topicSelect">
                        <option value="">-- Vyber téma --</option>
                    </select>
                </div>

                <!-- DEN (správné hodnoty enumu DayOfWeek) -->
                <div class="col-md-3">
                    <label>Den</label>
                    <select name="NewDay" class="form-control">
                        <option value="1">Pondělí</option>
                        <option value="2">Úterý</option>
                        <option value="3">Středa</option>
                        <option value="4">Čtvrtek</option>
                        <option value="5">Pátek</option>
                        <option value="6">Sobota</option>
                        <option value="0">Neděle</option>
                    </select>
                </div>

            </div>

            <div class="row mt-3">

                <!-- ZAČÁTEK -->
                <div class="col-md-3">
                    <label>Začátek</label>
                    <input name="NewStart" type="time" class="form-control" />
                </div>

                <!-- KONEC -->
                <div class="col-md-3">
                    <label>Konec</label>
                    <input name="NewEnd" type="time" class="form-control" />
                </div>

                <!-- NOTIFIKACE -->
                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check mt-4">
                        <input name="NotifyStudentOnDelete" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">
                            Odeslat zrušení studentovi při smazání lekce
                        </label>
                    </div>
                </div>

            </div>

            <button class="btn btn-primary mt-3">Přidat hodinu</button>

        </form>
    </div>
}

else
{
    <div class="card p-3 mb-4 shadow-sm bg-warning-subtle">
        <h5>Upravit hodinu</h5>

        <form method="post" asp-page-handler="Update">

            <input type="hidden" name="Week" value="@Model.Week.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="id" value="@Model.EditPlan.Id" />

            <div class="row">

                <!-- STUDENT -->
                <div class="col-md-3">
                    <label>Student</label>
                    <select name="StudentId" class="form-control">
                        @foreach (var s in Model.Students)
                        {
                            <option value="@s.Id"
                                    selected="@(s.Id == Model.EditPlan.StudentId)">
                                @s.LastName @s.FirstName
                            </option>
                        }
                    </select>
                </div>

                <!-- PŘEDMĚT -->
                <div class="col-md-3">
                    <label>Předmět</label>
                    <select name="SubjectId" class="form-select">
                        @foreach (var s in Model.Subjects)
                        {
                            <option value="@s.Id"
                                    selected="@(s.Id == Model.EditPlan.SubjectId)">
                                @s.Name
                            </option>
                        }
                    </select>
                </div>

                <!-- TÉMA -->
                <div class="col-md-3">
                    <label>Téma</label>
                    <select name="SubjectTopicId" class="form-select">
                        <option value="">-- Vyber téma --</option>
                        @foreach (var t in Model.Topics.Where(t => t.SubjectId == Model.EditPlan.SubjectId))
                        {
                            <option value="@t.Id"
                                    selected="@(t.Id == Model.EditPlan.SubjectTopicId)">
                                @t.Name
                            </option>
                        }
                    </select>
                </div>

                <!-- ZAČÁTEK -->
                <div class="col-md-3">
                    <label>Začátek</label>
                    <input name="Start"
                           type="time"
                           class="form-control"
                           value="@Model.EditPlan.Start.ToString("hh\\:mm")" />
                </div>

                <!-- KONEC -->
                <div class="col-md-3 mt-3">
                    <label>Konec</label>
                    <input name="End"
                           type="time"
                           class="form-control"
                           value="@Model.EditPlan.End.ToString("hh\\:mm")" />
                </div>

            </div>

            <button class="btn btn-success mt-3">Uložit</button>

            <button class="btn btn-secondary mt-3"
                    formmethod="post"
                    formaction="?handler=EditCancel">
                Zrušit
            </button>

        </form>
    </div>
}


@{
    var safeStart2 = Model.StartOfWeek == DateTime.MinValue
        ? DateTime.Today
        : Model.StartOfWeek;
}

<div class="row">

    @for (int i = 0; i < 7; i++)
    {
        var date = safeStart2.AddDays(i);

        <div class="col-12 col-md-1 border p-2 text-center" style="min-width: 180px;">

            <strong>
                @(
                    CultureInfo.GetCultureInfo("cs-CZ")
                        .TextInfo
                        .ToTitleCase(date.ToString("dddd", new CultureInfo("cs-CZ")))
                )
            </strong><br />

            @date.ToString("dd.MM.")

            <hr />

            @foreach (var p in Model.Plans.Where(p => p.Date.Date == date.Date))
            {
                var taughtStyle = p.IsTaught
                    ? "opacity:0.7;border-left:4px solid #28a745;"
                    : "";

                <div class="p-2 mb-2 rounded text-start"
                     style="background-color:@Model.GetColorForStudent(p.StudentId);@taughtStyle">

                    <strong>@p.Student.LastName @p.Student.FirstName</strong><br />
                    @p.Subject.Name – @p.SubjectTopic?.Name<br />
                    @p.Start.ToString(@"hh\:mm") – @p.End.ToString(@"hh\:mm")<br />

                    @if (!string.IsNullOrEmpty(p.MeetLink))
                    {
                        <a href="@p.MeetLink" target="_blank">Meet</a><br />
                    }

                    <div class="d-flex flex-row flex-nowrap gap-1 mt-1 align-items-center">

                        @if (!p.IsTaught)
                        {
                            <form method="post" asp-page-handler="Teach" class="m-0 p-0">
                                <input type="hidden" name="id" value="@p.Id" />
                                <input type="hidden" name="Week" value="@Model.Week.ToString("yyyy-MM-dd")" />

                                <button class="btn btn-success btn-sm px-1 py-0"
                                        title="Označit jako odučené">
                                    ✔
                                </button>
                            </form>
                        }

                        <form method="post" asp-page-handler="EditStart" class="m-0 p-0">
                            <input type="hidden" name="id" value="@p.Id" />
                            <input type="hidden" name="Week" value="@Model.Week.ToString("yyyy-MM-dd")" />

                            <button class="btn btn-warning btn-sm px-1 py-0"
                                    title="Upravit lekci">
                                ✏
                            </button>
                        </form>

                        <form method="post" asp-page-handler="Delete" class="m-0 p-0">
                            <input type="hidden" name="id" value="@p.Id" />
                            <input type="hidden" name="Week" value="@Model.Week.ToString("yyyy-MM-dd")" />

                            <button class="btn btn-danger btn-sm px-1 py-0"
                                    title="Smazat lekci">
                                🗑
                            </button>
                        </form>

                    </div>

                </div>
            }
        </div>
    }

</div>

@section Scripts {
    <script>
        const subjectSelect = document.getElementById("subjectSelect");
        const topicSelect = document.getElementById("topicSelect");

        if (subjectSelect && topicSelect) {
            subjectSelect.addEventListener("change", function () {
                const subjectId = this.value;

                fetch(`?handler=Topics&subjectId=${subjectId}`)
                    .then(response => response.json())
                    .then(data => {
                        topicSelect.innerHTML = '<option value="">-- Vyber téma --</option>';

                        data.forEach(t => {
                            const opt = document.createElement("option");
                            opt.value = t.id;
                            opt.textContent = t.name;
                            topicSelect.appendChild(opt);
                        });
                    })
                    .catch(err => console.error("Chyba při načítání témat:", err));
            });
        }
    </script>
}
