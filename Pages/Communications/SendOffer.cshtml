@page
@model Vyuka.Pages.Communications.SendOfferModel
@{
    ViewData["Title"] = "Univerzální emailová komunikace";
}

<h2 class="mb-4">Univerzální emailová komunikace</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}


<form method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label class="form-label">Student</label>
        <select asp-for="SelectedStudentId" class="form-select" asp-items="Model.StudentList">
            <option value="">-- Vyberte studenta --</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Předmět</label>
        <input asp-for="Subject" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Zpráva</label>
        <textarea asp-for="Message" class="form-control" rows="5"></textarea>
    </div>

    <!-- ⭐ PŘÍLOHY -->
    <div class="mb-3">
        <label class="form-label">Přílohy</label>
        <input type="file"
               name="Attachments"
               id="Attachments"
               class="form-control"
               multiple />

    </div>

    <button type="submit" class="btn btn-primary">Odeslat email</button>
</form>


@if (Model.PreviewHtml != null)
{
    <hr />
    <h3>Náhled e‑mailu</h3>
    <div class="border p-3">
        @Html.Raw(Model.PreviewHtml)
    </div>
}
