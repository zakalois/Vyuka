@page
@model Vyuka.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Změna hesla";
}

<div class="change-wrapper">

    <div class="change-card">

        <h2>Změna hesla</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }

        <form method="post">

            <div class="form-group">
                <label>Současné heslo</label>
                <input type="password" class="form-control" asp-for="Input.OldPassword" />
            </div>

            <div class="form-group">
                <label>Nové heslo</label>
                <input type="password" class="form-control" asp-for="Input.NewPassword" />
            </div>

            <div class="form-group">
                <label>Potvrzení nového hesla</label>
                <input type="password" class="form-control" asp-for="Input.ConfirmPassword" />
            </div>

            <button type="submit" class="btn btn-primary">Změnit heslo</button>
            <a href="/Account/Profile" class="btn btn-secondary">Zpět na profil</a>

        </form>

    </div>

</div>

<style>
    .change-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 40px;
    }

    .change-card {
        background: #fff;
        padding: 30px;
        border-radius: 12px;
        width: 500px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ccc;
    }

    .btn {
        padding: 10px 18px;
        border-radius: 6px;
        text-decoration: none;
        color: white;
        font-weight: 600;
        margin-right: 10px;
    }

    .btn-primary { background: #007bff; }
    .btn-secondary { background: #6c757d; }

    .alert {
        padding: 10px;
        border-radius: 6px;
        margin-bottom: 15px;
    }

    .alert-danger { background: #f8d7da; color: #721c24; }
    .alert-success { background: #d4edda; color: #155724; }
</style>
