@page "/Admin/Students"
@model Vyuka.Pages.Admin.Students.IndexModel

<style>
    .row-pink {
        background-color: #f8d7da !important;
    }

    /* učitel – přiřazen */
    .teacher-cell.has-teacher {
        background-color: #d4f8d4; /* světle zelená */
        color: #0f7a0f; /* tmavě zelená */
        font-weight: 600;
    }

    /* učitel – nepřiřazen */
    .teacher-cell.no-teacher {
        background-color: #ffd6d6; /* světle červená */
        color: #b30000; /* tmavě červená */
        font-weight: 600;
    }
</style>

<h1>Seznam studentů</h1>

<div class="d-grid mb-3">
    <a class="btn btn-primary btn-lg w-100" asp-page="Create">
        Přidat studenta
    </a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Příjmení</th>
            <th>Jméno</th>
            <th>Věk</th>
            <th class="text-start">Email</th>
            <th>Telefon R</th>
            <th>Telefon S</th>
            <th>Učitel</th>
            <th class="text-center" style="width:110px;">Akce</th>
        </tr>
    </thead>


    <tbody>
        @foreach (var item in Model.Students)
        {
            <tr class="@(item.Student.IsActive ? "" : "row-pink")">

                <td>@item.Student.LastName</td>
                <td>@item.Student.FirstName</td>
                <td>@item.Student.Age</td>

                <!-- ⭐ EMAIL vlevo -->
                <td class="text-start">@item.Student.Email</td>

                <td>
                    @if (!string.IsNullOrWhiteSpace(item.Student.ParentPhone))
                    {
                        @item.Student.ParentPhone
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>


                <td>
                    @if (!string.IsNullOrWhiteSpace(item.Student.Phone))
                    {
                        @item.Student.Phone
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>



                <!-- ⭐ UČITEL – barevné podbarvení -->
                <td class="teacher-cell @(item.Student.Teacher != null ? "has-teacher" : "no-teacher")">
                    @if (item.Student.Teacher != null)
                    {
                        <span title="@item.Student.Teacher.User?.Email">
                            @item.Student.Teacher.FullName
                        </span>
                    }
                    else
                    {
                        <span>
                            <i class="bi bi-exclamation-circle"></i> Nepřiřazen
                        </span>
                    }
                </td>

                <!-- ⭐ AKCE -->
                <td class="text-center" style="white-space:nowrap;">

                    <a asp-page="Edit" asp-route-id="@item.Student.Id" class="text-primary me-2" title="Upravit">
                        <i class="bi bi-pencil-square"></i>
                    </a>

                    <a asp-page="Details" asp-route-id="@item.Student.Id" class="text-info me-2" title="Detail">
                        <i class="bi bi-search"></i>
                    </a>

                    <a asp-page="Delete" asp-route-id="@item.Student.Id" class="text-danger me-3" title="Smazat">
                        <i class="bi bi-trash"></i>
                    </a>

                    <a asp-page="/Admin/Students/AssignTeacher"
                       asp-route-id="@item.Student.Id"
                       asp-route-returnUrl="@HttpContext.Request.Path@HttpContext.Request.QueryString"
                       class="btn btn-outline-dark btn-sm"
                       title="Přiřadit učitele">
                        <i class="bi bi-person-fill-gear"></i>
                    </a>

                </td>

            </tr>
        }
    </tbody>

</table>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    });
</script>
