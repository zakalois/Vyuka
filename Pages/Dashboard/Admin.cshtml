@page
@model Vyuka.Pages.Dashboard.AdminModel
@using Microsoft.AspNetCore.Http

@{
    Layout = null;
    ViewData["Title"] = "Řídicí panel Administrátora";

    var userName = !string.IsNullOrEmpty(User.Identity?.Name)
        ? User.Identity.Name
        : "Přihlášený uživatel";

    var userRole = HttpContext.Session.GetString("UserRole") ?? "Role neznámá";
}

<style>
    :root {
        --primary: #1e3a8a;
        --primary-light: #3b82f6;
        --bg: #f1f5f9;
        --text: #1e293b;
        --white: #ffffff;
    }

    body.dark {
        --bg: #0f172a;
        --text: #f8fafc;
        --white: #1e293b;
        --primary: #60a5fa;
        --primary-light: #93c5fd;
    }

    body.dark .kpi-value { color: #f1f5f9; }
    body.dark .kpi-title,
    body.dark .kpi-sub { color: #e2e8f0; }
    body.dark .profile-inline .profile-name { color: #f1f5f9; }
    body.dark .profile-inline .profile-role { color: #e2e8f0; }

    body {
        margin: 0;
        font-family: "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        transition: 0.3s;
    }

    header {
        background: var(--primary);
        color: white;
        padding: 18px 32px;
        font-size: 24px;
        font-weight: 600;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .dark-toggle {
        background: var(--primary-light);
        color: white;
        padding: 8px 14px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        border: none;
    }

    .container {
        max-width: 1200px;
        margin: 32px auto;
        padding: 0 20px;
    }

    .user-kpi-row {
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 30px;
        align-items: center;
        margin-bottom: 32px;
    }

    .profile-inline {
        text-align: center;
    }

    .profile-inline img {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--primary-light);
    }

    .profile-inline .profile-name {
        margin-top: 10px;
        font-size: 18px;
        font-weight: 700;
        color: var(--primary);
    }

    .profile-inline .profile-role {
        margin-top: 4px;
        font-size: 15px;
        font-weight: 600;
        opacity: 0.8;
        color: var(--primary-light);
    }

    .profile-inline .logout-link {
        margin-top: 10px;
        font-size: 14px;
        font-weight: 600;
    }

    .profile-inline .logout-link a {
        color: var(--primary-light);
        text-decoration: none;
    }

    .profile-inline .logout-link a:hover {
        color: var(--primary);
    }

    .kpi-inline-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .kpi-box {
        background: var(--white);
        padding: 28px;
        border-radius: 12px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
        text-align: center;
    }

    .kpi-title {
        font-size: 14px;
        opacity: 0.7;
    }

    .kpi-value {
        font-size: 34px;
        font-weight: 700;
        margin-top: 8px;
        color: var(--primary);
    }

    .kpi-sub {
        font-size: 18px;
        margin-top: 4px;
        opacity: 0.8;
    }

    .actions {
        margin-bottom: 32px;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .btn {
        background: var(--primary-light);
        color: white;
        padding: 12px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.2s;
    }

    .btn:hover {
        background: var(--primary);
    }

    .section-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 32px;
    }

    .section-box {
        background: var(--white);
        padding: 24px;
        border-radius: 12px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
        text-align: center;
        font-size: 18px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
        text-decoration: none;
        color: var(--text);
    }

    .section-box:hover {
        background: #e2e8f0;
    }

    .gmail-box {
        background: var(--white);
        padding: 24px;
        border-radius: 12px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
        margin-bottom: 32px;
    }

    .gmail-box h3 {
        margin-top: 0;
        text-align: center;
    }

    .google-switch a {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin: 6px;
        padding: 12px 20px;
        background: var(--primary-light);
        color: white;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.2s;
    }

    .google-switch a:hover {
        background: var(--primary);
    }

    .google-icon {
        width: 22px;
        height: 22px;
    }

    iframe {
        width: 100%;
        height: 400px;
        border: none;
        border-radius: 12px;
    }
</style>

<header>
    Řídicí panel Administrátora
    <button id="darkToggle" class="dark-toggle" type="button">
        Tmavý režim
    </button>
</header>

<div class="container">

    <div class="user-kpi-row">
        <div class="profile-inline">
            <img src="/images/profile-user.jpg" alt="Profil">
            <div class="profile-name">@userName</div>
            <div class="profile-role">@userRole</div>

            <div class="logout-link">
                <a href="/Logout">Odhlásit se</a>
            </div>
        </div>

        <div class="kpi-inline-grid">
            <div class="kpi-box">
                <div class="kpi-title">Studenti</div>
                <div class="kpi-value">24</div>
            </div>

            <div class="kpi-box">
                <div class="kpi-title">Hodiny tento týden</div>
                <div class="kpi-value">8</div>
            </div>

            <div class="kpi-box">
                <div class="kpi-title">Nejbližší lekce</div>
                <div class="kpi-value">
                    @(Model.NextLessonDate?.ToString("d. MMMM") ?? "Žádná lekce")
                </div>
                <div class="kpi-sub">
                    @(Model.NextLessonDate?.ToString("HH:mm") ?? "")
                </div>
            </div>
        </div>
    </div>

    <div class="actions">
    <a class="btn" href="/Students/Create">Přidat studenta</a>
    <a class="btn" href="/Students">Studenti</a>
    <a class="btn" href="/Schedule">Rozvrh</a>
    <a class="btn" href="/Offers/Create">Vytvořit nabídku</a>
    <a class="btn" href="/Payments/Index">Finance</a>
</div>


    <!--
<div class="section-grid">
    <a class="section-box" href="/Students">Studenti</a>
    <a class="section-box" href="/Lessons">Hodiny</a>
    <a class="section-box" href="/Payments">Finance</a>
</div>
-->


    <div class="gmail-box">
        <h3>Online služby</h3>

        <div class="google-switch" style="text-align:center; margin-bottom:15px;">

            <a href="https://mail.google.com" target="_blank">
                <img class="google-icon" src="https://www.gstatic.com/images/branding/product/1x/gmail_48dp.png" alt="">
                Gmail
            </a>

            <a href="https://calendar.google.com" target="_blank">
                <img class="google-icon" src="https://www.gstatic.com/images/branding/product/1x/calendar_48dp.png" alt="">
                Kalendář
            </a>

            <a href="https://meet.google.com" target="_blank">
                <img class="google-icon" src="https://www.gstatic.com/images/branding/product/1x/meet_48dp.png" alt="">
                Meet
            </a>

            <a href="https://drive.google.com" target="_blank">
                <img class="google-icon" src="https://www.gstatic.com/images/branding/product/1x/drive_48dp.png" alt="">
                Drive
            </a>

            <a href="https://web.whatsapp.com" target="_blank">
                <img class="google-icon" src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" alt="">
                WhatsApp
            </a>

            <a href="/Communications">
                <img class="google-icon" src="https://upload.wikimedia.org/wikipedia/commons/4/4e/Mail_%28iOS%29.svg" alt="">
                E‑mailová komunikace
            </a>

        </div>

        <p style="text-align:center; opacity:0.7; font-size:14px;">
            Google služby se otevřou v novém okně.  
            E‑mailová komunikace se otevře zde v aplikaci.
        </p>
    </div>
</div>

<script>
    (function () {
        const body = document.body;
        const toggle = document.getElementById('darkToggle');

        const saved = localStorage.getItem('theme');
        if (saved === 'dark') {
            body.classList.add('dark');
            toggle.textContent = 'Světlý režim';
        }

        toggle.addEventListener('click', function () {
            body.classList.toggle('dark');
            const isDark = body.classList.contains('dark');
            toggle.textContent = isDark ? 'Světlý režim' : 'Tmavý režim';
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
    })();
</script>
